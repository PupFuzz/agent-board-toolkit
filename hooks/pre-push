#!/usr/bin/env bash
# agent-board-toolkit pre-push hook.
# Fail-soft ADVISORY (card-4621): warn when a branch being pushed looks like it names a
# card in a spelling the board auto-move grammar won't recognize — so the card would
# silently never move to In Progress — and point at the compliant spelling. This hook
# NEVER blocks a push: it always exits 0, whatever the advisory finds.
#
# Install with: bin/install-board-hooks <repo>   (symlinks this file into .git/hooks)
#
# git feeds one "<local-ref> <local-sha> <remote-ref> <remote-sha>" line per pushed ref
# on stdin. We lint each pushed local branch via `board-card-start --lint` (which reuses
# the exact card-id grammar, so the lint and the auto-move never disagree).
command -v board-card-start >/dev/null 2>&1 || exit 0

while read -r local_ref _ _ _; do
    case "$local_ref" in
        refs/heads/*) board-card-start --lint "${local_ref#refs/heads/}" || true ;;
    esac
done

exit 0
