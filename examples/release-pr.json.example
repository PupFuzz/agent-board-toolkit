{
  "_comment": "agent-board-toolkit per-repo release config. Copy to <your-repo>/.release-pr.json and edit. Consumed by bin/release-pr-body (scaffolds the release PR body) and bin/promote-released-cards (moves shipped cards to the released stage). JSON has no comments; each field is documented in agent-board-toolkit/docs/INSTALL.md §4. Replace every placeholder.",
  "title_prefix": "Release",
  "dev_branch": "dev",
  "main_branch": "main",
  "version_file": "config/app.php",
  "version_regex": "'version' => '[0-9.]+'",
  "ref_token_regex": "DL-[0-9]+",
  "artifacts": [
    "config/app.php → {{version}}",
    "docs/CHANGELOG.md → [{{version}}] section"
  ],
  "promote": {
    "board_id": 0,
    "released_stage_id": 0,
    "api_base": "https://YOUR-KANBAN-HOST/api/v3"
  }
}
