# agent-board-toolkit — per-board config (source of board/stage/type/custom-field IDs)
# ---------------------------------------------------------------------------
# Copy this to a real file and fill in YOUR board's numeric IDs:
#     cp examples/kanban-board.env.example ~/.kanban-myproject-board.env
#     chmod 600 ~/.kanban-myproject-board.env
#
# `kbcard` sources this file; the `--board <name>` flag selects which env file
# (it looks for ~/.kanban-<name>-board.env). See docs/INSTALL.md §3.
#
# HOW TO FIND THE IDs (replace YOUR-KANBAN-HOST + <board-id>):
#   stages : GET https://YOUR-KANBAN-HOST/api/v3/boards/<board-id>/workflows.json   -> .data[].workflow_stages[] {id,name}
#   types  : GET https://YOUR-KANBAN-HOST/api/v3/boards/<board-id>/card_types.json   -> .data[] {id,name}
#   fields : GET https://YOUR-KANBAN-HOST/api/v3/boards/<board-id>/custom_fields.json -> .data[] {id,key}
# Map each returned id to the matching key below. Names here are illustrative —
# use whatever columns/types/fields YOUR board actually has. The `kbcard` column
# and card-type ALIASES (e.g. `bug`, `in_progress`, `wont_do`) are a fixed set in
# the script; a board with a different taxonomy maps its ids onto the closest
# aliases, or extends the `case` blocks locally and drift-checks against upstream
# (per the vendor model — never a silent contract fork). `--board <name>` +
# `KANBAN_SNAPSHOT_BOARDS` (board-snapshot) + `KB_DL_CHECKOUT_GLOBS` (next-dl) make
# the roster/checkouts config-driven for a PM-project adopter.

export KB_BOARD_ID=000            # the board's numeric id
export KB_WORKFLOW_ID=000         # the board's workflow id

# --- Workflow stage IDs (your columns) ---
export KB_STAGE_BACKLOG=000
export KB_STAGE_PRIORITIZED=000
export KB_STAGE_IN_PROGRESS=000
export KB_STAGE_IN_REVIEW=000
export KB_STAGE_SHIPPED_TO_DEV=000
export KB_STAGE_RELEASED_TO_MAIN=000

# --- Card type IDs ---
export KB_TYPE_DL=000
export KB_TYPE_RELEASE=000
export KB_TYPE_REQUEST=000
export KB_TYPE_IDEA=000
export KB_TYPE_BUG=000

# --- Custom field IDs ---
# NOTE (BR-3.2): `kbcard` writes payload by its CONTRACT-FIXED keys — `dl_number`,
# `pr_number`, `version_target`, `origin` (the canonical external-reference keys
# kanban maps; do not rename them). It does NOT read most KB_CF_* ids — they're
# informational here (and consumed by other tooling). The one that IS read is
# KB_CF_VERSION_TARGET: `kbcard --version` writes `version_target` ONLY when it's
# set (non-`000`), so a board WITHOUT a version_target field can leave it `000`
# and `--version` is skipped (with a warning) instead of 422-ing. Boards that
# lack a field simply leave its id `000`.
export KB_CF_DL_NUMBER=000
export KB_CF_PR_NUMBER=000
export KB_CF_VERSION_TARGET=000   # leave 000 if your board has no version_target field → --version is skipped
export KB_CF_ORIGIN=000

# --- Optional overrides (defaults shown) ---
# NOTE: KBCARD_API is board-independent — set it ONCE in ~/.kanban-host.env, NOT
# here. As of v0.14.0 a board env that sets it is REFUSED, naming this file, rather
# than silently guessing which host you meant: kbcard / dl-a0-backfill-triaged /
# dl-a1-register-field / adopt-to-dl exit 2, while next-dl warns, skips the board
# check and still mints offline (fail-soft). board-snapshot and board-card-start
# never read it from here at all. (See docs/INSTALL.md §3.)
# Token file (a file containing ONLY the bearer token; chmod 600; never committed).
# Honored from this board env (resolved AFTER sourcing). Set it for any non-default
# board: when unset the hardcoded fallback is ~/.kanban-dev-token, so a `--board
# myproject` call would otherwise use the DEFAULT board's token, not this one's:
# export KBCARD_TOKEN_FILE="$HOME/.kanban-myproject-token"
