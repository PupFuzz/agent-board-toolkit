# agent-board-toolkit — host/API config (board-INDEPENDENT)
# ---------------------------------------------------------------------------
# Copy to ~/.kanban-host.env (chmod 600). Sourced by kbcard + board-snapshot so
# no install's host is baked into the shared tool. One file per host, shared by
# all boards on that host. Override the path with $KANBAN_HOST_ENV if needed.
#
#     cp examples/kanban-host.env.example ~/.kanban-host.env
#     chmod 600 ~/.kanban-host.env
#     # then edit KBCARD_API below to your kanban host

export KBCARD_API="https://YOUR-KANBAN-HOST/api/v3"

# Optional: a default token file used when a board env doesn't set its own
# KBCARD_TOKEN_FILE (a file containing ONLY the bearer token; chmod 600):
# export KBCARD_TOKEN_FILE="$HOME/.kanban-dev-token"
