#!/usr/bin/env bash
# board-card-start — move the card correlated to a feature branch into "In Progress".
#
# Codifies "work has begun" so it's never a forgotten manual step (the recurring
# board-drift fix). Called by the post-checkout git hook; also runnable by hand:
#     board-card-start [<branch-name>]      (default: the current branch)
#
# Correlation — try-in-order-with-fallback (framework contract #112), on the
# OUTCOME of a token not its presence:
#   1. A DL-NNN token (e.g. feature/dl156-foo) that RESOLVES → the board card whose
#      payload.dl_number is DL-NNN. A co-present card-id token is ignored (loud).
#   2. A DL-NNN that resolves to NO card → fall through to a CARD-ID token in the
#      same branch (never dead-end — the unstamped-card class). When we resolve via
#      the card-id path AND a DL was named, payload.dl_number is STAMPED if empty
#      (never overwriting a differing stamp) so downstream DL-correlated movers stop
#      no-op'ing on the card.
#   3. No DL token → a CARD-ID token → that card (task) id directly. Recognized as
#      an explicit `card#2950` (the bridge's grammar) / `#2950` / `card-2950` /
#      `card/2950` anywhere, or the leading
#      id of a typed branch (`feat/2950-…`, `fix/2950`, `chore/2950/…`). This is
#      how routine FR/bug work — branched by card id before a DL is assigned —
#      still moves. The card-id path only ever moves a card that actually lives
#      on the repo's configured board (the board-match guard below), so a stray
#      number can't promote an unrelated task.
#   4. A DL present but resolving to nothing with no card-id fallback → loud no-op
#      (a high-value miss), never silent.
#
# SAFE BY DESIGN:
#   - FAIL-SOFT: any missing config / unreachable board / no match → exit 0. It
#     must NEVER block a git checkout.
#   - IDEMPOTENT + no stage regression: promotes a card in Backlog or Prioritized
#     on any branch checkout, and a Held card ONLY on a genuine branch CREATION
#     (contract PR #113 — a re-checkout of an old branch won't un-park it). A card
#     already In Progress / In Review / Shipped / Released / Won't-Do is left alone.
#   - PINNED cards are never auto-moved: a non-empty block_reason or a `no-automove`
#     tag refuses the move (loud), regardless of stage.
#   - BOARD-SCOPED: the resolved card must be on the repo's configured board.
set -uo pipefail

# Shared toolkit lib (DL canon, whole-board pagination, token read). Fail-soft:
# a missing lib must never block a git checkout.
KB_LIB="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/_kb-board-lib.sh"
# shellcheck source=bin/_kb-board-lib.sh
[ -r "$KB_LIB" ] || exit 0
source "$KB_LIB"
KB_PROG="board-card-start"

branch="${1:-$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)}"
[ -n "$branch" ] && [ "$branch" != "HEAD" ] || exit 0

# DL token from the branch name (case-insensitive); kb_dl_num strips zeros and
# rejects a non-DL, so a malformed token degrades to the card-id path below.
dltok="$(printf '%s\n' "$branch" | grep -oiE 'dl-?[0-9]+' | head -1 || true)"
dl=""
[ -n "$dltok" ] && dl="$(kb_dl_num "$dltok" 2>/dev/null || true)"

# Card-id token — ALWAYS extracted (framework contract #112): a DL that resolves
# to no card falls through to the card-id path, so the native id must be available
# even when a DL token is also present. Extraction is card-id-specific (an explicit
# `#2950` / `card-2950` / `card/2950`, or a typed branch's leading >=3-digit id
# directly after a known type prefix, token-bounded so `feat/2signup`, a 2-digit
# version, or a `dl-189` token can't match), so it never mis-reads a DL as a card id.
cid_token="$(printf '%s\n' "$branch" | grep -oiE '(^|[/_-])(card[-/#]|#)0*[0-9]{2,}' | grep -oE '[0-9]+' | head -1 | sed 's/^0*//')"
[ -n "$cid_token" ] || cid_token="$(printf '%s\n' "$branch" \
    | grep -oiE '^(feat|feature|fix|hotfix|bug|chore|fr|refactor|perf|docs|ci|test|build|style)/#?0*[0-9]{3,}([/_-]|$)' \
    | grep -oE '[0-9]{3,}' | head -1 | sed 's/^0*//')"

[ -n "$dl" ] || [ -n "$cid_token" ] || exit 0

command -v curl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1 || exit 0

# Board id + API base. `board_id` always comes from the repo's committed
# .release-pr.json (not a secret). The `api_base` does too — EXCEPT the committed
# value is usually a host-scrubbed RFC-2606 placeholder (`*.example.com`), because
# the real kanban host must not live in a repo (bridge #218 / toolkit host-scrub).
# When the committed api_base is such a placeholder, fall back to $KB_API — the real
# host this script already resolves from ~/.kanban-host.env (KBCARD_API) via
# kb_load_host_token below — so the post-checkout hook reaches the real board with
# NO per-repo config. A genuinely real committed host (a multi-host install that did
# not scrub) is not a placeholder, so it is used as-is.
root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
cfg="$root/.release-pr.json"
[ -n "$root" ] && [ -r "$cfg" ] || exit 0
board="$(jq -r '.promote.board_id // empty' "$cfg" 2>/dev/null)"
committed_api="$(jq -r '.promote.api_base // empty' "$cfg" 2>/dev/null)"
[ -n "$board" ] || exit 0

# Token + host env (sources ~/.kanban-host.env, publishing KB_API=KBCARD_API and the
# token). Unconditional so a host-env KBCARD_TOKEN_FILE override always wins. Reads
# the token into memory only (not sent until the guarded curls below). Fail-soft.
kb_load_host_token unconditional || exit 0
token="$KB_TOKEN"

# Effective api_base: the committed value, unless it is a documentation-placeholder
# host (host-scrubbed) — then the host-env-resolved KB_API is the real one. The
# regex must track the host-scrub's placeholder form: today the scrub emits
# `*.example.com` (RFC-2606 reserved), so match example.{com,net,org}. If the scrub
# ever switches to the bare `.example` TLD, widen this accordingly.
api="$committed_api"
if [ -z "$api" ] || printf '%s' "$api" | grep -qiE '://([^/]*\.)?example\.(com|net|org)([:/]|$)'; then
    api="${KB_API:-}"
fi
if [ -z "$api" ]; then
    echo "board-card-start: no usable kanban api_base — committed .release-pr.json is host-scrubbed and \$KBCARD_API is unset (create ~/.kanban-host.env; see docs/INSTALL.md). No move." >&2
    exit 0
fi

# Guard the api_base before sending the token — a malicious .release-pr.json edit (or
# host-env value) must not exfiltrate the token to an untrusted host (#3570). Fail-SOFT
# (exit 0 — this runs from a post-checkout hook and must NEVER block a checkout) but
# LOUD on stderr; the token is simply never sent when the host isn't trusted.
kb_require_https_host "$api" || exit 0

# Stage ids for THIS board, from the matching ~/.kanban-*-board.env.
stages="$(
  for envf in "$HOME"/.kanban-*-board.env; do
    [ -r "$envf" ] || continue
    # shellcheck disable=SC1090
    ( . "$envf" 2>/dev/null; [ "${KB_BOARD_ID:-}" = "$board" ] \
        && printf '%s %s %s %s\n' "${KB_STAGE_IN_PROGRESS:-}" "${KB_STAGE_BACKLOG:-}" "${KB_STAGE_PRIORITIZED:-}" "${KB_STAGE_HELD:-}" )
  done | head -1
)"
read -r inprog backlog prioritized held <<<"$stages"
# Held is optional (a board may not have the column); backlog/prioritized/in_progress
# are required for any promotion to make sense.
[ -n "$inprog" ] && [ -n "$backlog" ] && [ -n "$prioritized" ] || exit 0

get() { curl -fsS -H @<(kb_auth_header "$token") -H "Accept: application/json" "$1" 2>/dev/null; }

# A branch CREATION is the genuine work-start signal for a Held card (contract
# PR #113); a re-checkout of an existing branch must not un-park it. The branch's
# reflog records `branch: Created from …` exactly once at creation and it stays the
# LAST entry (commits/checkouts prepend). On `git switch -c` the post-checkout hook
# fires with that entry ~0s old; a later re-checkout sees it aged. A fresh clone
# landing on an existing branch logs `clone: …`, which does not match — so cloning
# can't un-park. Fail-soft: no reflog / unparsable timestamp → NOT a creation.
branch_just_created() {
    local last ts age
    last="$(git reflog show --date=unix "$branch" 2>/dev/null | tail -1)" || return 1
    printf '%s' "$last" | grep -q 'branch: Created from' || return 1
    ts="$(printf '%s' "$last" | grep -oE '@\{[0-9]+\}' | tr -d '@{}')"
    [ -n "$ts" ] || return 1
    age=$(( $(date +%s) - ts ))
    [ "$age" -ge 0 ] && [ "$age" -le "${KB_HELD_CREATE_MAX_AGE:-15}" ]
}

# Resolve the card (task) id to move — try-in-order-with-fallback (framework #112):
# resolve on the OUTCOME of a token, not its presence. via_cardid records that the
# card was selected by native id (the stamp step below keys on it).
via_cardid=0
if [ -n "$dl" ]; then
    # Whole-board paginated fetch (fix: was page-1 only, so a DL beyond page 1 was
    # missed). Match NUMERICALLY on the dl_number's digits so every stored form —
    # "DL-093" (legacy 3-pad), "DL-0156" (canonical), or a bare 156 — resolves.
    cards="$(fetch_board_cards "$api" "$token" "$board")" || exit 0
    cid="$(printf '%s' "$cards" | jq -r --argjson want "$dl" '
        [ .[]
          | (.payload.dl_number // empty) as $raw
          | ($raw | tostring) as $s
          | select($s | test("[0-9]"))
          | select(($s | capture("(?<n>[0-9]+)").n | tonumber) == $want)
          | .id ] | .[0] // empty' 2>/dev/null)"
    if [ -n "$cid" ]; then
        # (1)/(3) DL resolved → it wins. A co-present card-id token is ignored (loud).
        label="DL-$dl"
        [ -n "$cid_token" ] && [ "$cid_token" != "$cid" ] \
            && echo "board-card-start: branch names DL-$dl (card #$cid) and #$cid_token — DL wins; #$cid_token ignored" >&2
    elif [ -n "$cid_token" ]; then
        # (2) DL tracks no card yet (the unstamped-card class) → fall through to the
        # card-id path instead of dead-ending. The stamp step below writes dl_number.
        cid="$cid_token"; label="#$cid_token"; via_cardid=1
        echo "board-card-start: DL-$dl matches no card — falling through to #$cid_token (framework #112)" >&2
    else
        # (4) DL present, unresolved, no card-id fallback → a high-value miss (a
        # decision-logged-but-unstamped card). Loud, never a silent no-op.
        echo "board-card-start: branch names DL-$dl but no card carries it and no card-id fallback token is present — no move" >&2
        exit 0
    fi
else
    cid="$cid_token"
    label="#$cid_token"
    via_cardid=1
fi
[ -n "$cid" ] || exit 0

# Fetch the card; read its current stage AND board. The board-match guard bounds
# the card-id path — a bare number can only move a card on the repo's own board.
card="$(get "$api/tasks/$cid.json")"
cur="$(printf '%s' "$card" | jq -r '.data.workflow_stage_id // empty')"
cbd="$(printf '%s' "$card" | jq -r '.data.board_id // empty')"
[ -n "$cur" ] && [ "$cbd" = "$board" ] || exit 0

# Opt-out (framework contract, agent-board-framework PR #113): a card a human has
# pinned — a non-empty block_reason OR a `no-automove` tag — is NEVER auto-moved,
# regardless of stage. Loud refusal so the skipped move is visible.
breason="$(printf '%s' "$card" | jq -r '.data.block_reason // empty')"
sticky="$(printf '%s' "$card" | jq -r 'any((.data.tags // [])[]; . == "no-automove")')"
if [ -n "$breason" ] || [ "$sticky" = "true" ]; then
    echo "board-card-start: card #$cid ($label) pinned (block_reason/no-automove) — auto-move refused" >&2
    exit 0
fi

# Stamp the dl_number write-site (framework contract #112 step 2). When the card
# was selected by native id AND the branch also names a DL, write payload.dl_number
# so the downstream DL-correlated movers (bridge writeback, release promote) stop
# no-op'ing on this card — the failure that stranded the #2179 class. if-empty only:
# never overwrite a differing stamp (loud warn); the API replaces payload WHOLESALE,
# so read-merge-write from the already-fetched card. Runs regardless of the stage-gate
# below (a card past the move stages still needs the stamp), but AFTER the pinned/
# opt-out guard — a hands-off card gets no automated write at all. Fail-soft — never blocks.
if [ "$via_cardid" = 1 ] && [ -n "$dl" ]; then
    curdl="$(printf '%s' "$card" | jq -r '.data.payload.dl_number // empty' 2>/dev/null)"
    curdl_num="$(printf '%s' "$curdl" | grep -oE '[0-9]+' | head -1 | sed 's/^0*//')"
    if [ -z "$curdl" ]; then
        want="$(kb_dl_canon "$dl" 2>/dev/null || true)"
        merged="$(printf '%s' "$card" | jq -c --arg dl "$want" \
            '(.data.payload | if type == "object" then . else {} end) + {dl_number: $dl}' 2>/dev/null)"
        if [ -n "$want" ] && [ -n "$merged" ] && curl -fsS -X PATCH -H @<(kb_auth_header "$token") \
             -H "Accept: application/json" -H "Content-Type: application/json" \
             --data "$(jq -nc --argjson p "$merged" '{task: {payload: $p}}')" \
             "$api/tasks/$cid.json" >/dev/null 2>&1; then
            echo "board-card-start: card #$cid stamped payload.dl_number=$want (was unstamped; DL-$dl named in branch)" >&2
        fi
    elif [ "$curdl_num" != "$dl" ]; then
        echo "board-card-start: card #$cid has dl_number=$curdl but branch names DL-$dl — NOT overwriting (stamp conflict)" >&2
    fi
fi

# Promote-from policy (contract PR #113):
#   - Backlog / Prioritized → promote on any branch checkout (unchanged: a
#     never-worked card advancing on a checkout is the intended work-start signal).
#   - Held → promote ONLY on a genuine branch CREATION. Re-checking-out an existing
#     branch onto a Held card is a deliberate no-op — the original re-fire
#     protection the manual-only default guaranteed. `branch_just_created` reads the
#     branch's own reflog (fail-soft: no reflog / unparsable → not-a-creation).
#   - Anything else (In Progress / In Review / Shipped / Released / Won't-Do) →
#     never touched.
case "$cur" in
    "$backlog" | "$prioritized") ;;
    "$held")
        # Reached only when cur == held (a non-empty stage id); promote only on a
        # genuine creation, else leave the parked card put.
        branch_just_created || exit 0
        ;;
    *) exit 0 ;;
esac

if curl -fsS -X PATCH -H @<(kb_auth_header "$token") -H "Accept: application/json" \
     -H "Content-Type: application/json" --data "{\"task\":{\"workflow_stage_id\":$inprog}}" \
     "$api/tasks/$cid.json" >/dev/null 2>&1; then
    echo "board-card-start: card #$cid ($label) → In Progress" >&2
fi
exit 0
