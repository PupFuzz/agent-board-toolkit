#!/usr/bin/env bash
# board-card-start — move the card correlated to a feature branch into "In Progress".
#
# Codifies "work has begun" so it's never a forgotten manual step (the recurring
# board-drift fix). Called by the post-checkout git hook; also runnable by hand:
#     board-card-start [<branch-name>]      (default: the current branch)
#
# Correlation — try-in-order-with-fallback (framework contract #112), on the
# OUTCOME of a token not its presence:
#   1. A DL-NNN token (e.g. feature/dl156-foo) that RESOLVES → the board card whose
#      payload.dl_number is DL-NNN. A co-present card-id token is ignored (loud).
#   2. A DL-NNN that resolves to NO card → fall through to a CARD-ID token in the
#      same branch (never dead-end — the unstamped-card class). When we resolve via
#      the card-id path AND a DL was named, payload.dl_number is STAMPED if empty
#      (never overwriting a differing stamp) so downstream DL-correlated movers stop
#      no-op'ing on the card.
#   3. No DL token → a CARD-ID token → that card (task) id directly. Recognized as
#      an explicit `card#2950` (the bridge's grammar) / `#2950` / `card-2950` /
#      `card/2950` anywhere, or the leading
#      id of a typed branch (`feat/2950-…`, `fix/2950`, `chore/2950/…`). This is
#      how routine FR/bug work — branched by card id before a DL is assigned —
#      still moves. The card-id path only ever moves a card that actually lives
#      on the repo's configured board (the board-match guard below), so a stray
#      number can't promote an unrelated task.
#   4. A DL present but resolving to nothing with no card-id fallback → loud no-op
#      (a high-value miss), never silent.
#
# SAFE BY DESIGN:
#   - FAIL-SOFT: any missing config / unreachable board / no match → exit 0. It
#     must NEVER block a git checkout.
#   - IDEMPOTENT + no stage regression: promotes a card in Backlog or Prioritized
#     on any branch checkout, and a Held card ONLY on a genuine branch CREATION
#     (contract PR #113 — a re-checkout of an old branch won't un-park it). A card
#     already In Progress / In Review / Shipped / Released / Won't-Do is left alone.
#   - PINNED cards are never auto-moved: a non-empty block_reason or a `no-automove`
#     tag refuses the move (loud), regardless of stage.
#   - BOARD-SCOPED: the resolved card must be on the repo's configured board.
set -uo pipefail

# Shared toolkit lib (DL canon, whole-board pagination, token read). Fail-soft:
# a missing lib must never block a git checkout.
KB_LIB="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/_kb-board-lib.sh"
# shellcheck source=bin/_kb-board-lib.sh
[ -r "$KB_LIB" ] || { echo "board-card-start: _kb-board-lib.sh not found next to this script — board automation skipped (reinstall per INSTALL.md §3, or co-vendor _kb-board-lib.sh alongside this hook)." >&2; exit 0; }
source "$KB_LIB"
KB_PROG="board-card-start"

# --- pure helpers (unit-tested by tests/board-card-start-selftest.sh) --------

# _bcs_is_placeholder_host <api_base>: true (0) when the api_base host is an RFC-2606/6761
# reserved documentation/placeholder host — the host-scrub emits such a host so the real
# kanban host never lives in a repo, and the hook then falls back to $KB_API. Each reserved
# label is anchored to a host-label boundary (leading '.' or the scheme '//', trailing ':' /
# '/' / end) so a REAL host that merely CONTAINS the substring — kanban.latest-corp.com
# (…test…), example-corp.net, mytest.io — is NOT misread as a placeholder (which would wrongly
# override it to $KB_API or reject a valid config, #34). Empty → placeholder (fall back to KB_API).
_bcs_is_placeholder_host() {
    local api="${1:-}"
    [ -z "$api" ] && return 0
    printf '%s' "$api" | grep -qiE '://([^/]*\.)?example\.(com|net|org)([:/]|$)|://([^/]*\.)?(invalid|test|example)([:/]|$)|://localhost([:/]|$)'
}

# kb_bcs_log <reason>: the loud + DURABLE diagnostic for an *attempted-but-failed* move (a
# branch that carries a DL/card token but whose card did not move for an infra reason). The
# installed wrapper runs `board-card-start >/dev/null 2>&1 || true`, so stderr is invisible on
# the hook path — the durable record is the log FILE (KB_BCS_LOG override). Best-effort and
# set -u-safe (every ref defaulted); it swallows its own errors so it can NEVER fail the hook
# (which must exit 0, never blocking a checkout). A manual `board-card-start` run still sees stderr.
kb_bcs_log() {
    local reason="${1:-unspecified}"
    local br="${branch:-?}"
    local msg="board-card-start: branch '$br' carries a DL/card token but the move did not happen — $reason"
    printf '%s\n' "$msg" >&2
    local logf="${KB_BCS_LOG:-${HOME:-/tmp}/.cache/agent-board-toolkit/board-card-start.log}"
    local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || printf '?')"
    { mkdir -p "$(dirname "$logf")" 2>/dev/null && printf '%s %s\n' "$ts" "$msg" >>"$logf" 2>/dev/null; } || true
}

# bcs_skip <reason>: record the attempted-but-failed reason (kb_bcs_log), then exit 0 — the
# hook is fail-soft and must never block a checkout. Only ever called PAST the token-presence
# gate below, so a token IS present: a genuine no-op (no token) stays silent and never reaches here.
bcs_skip() { kb_bcs_log "$1"; exit 0; }

# _bcs_patch <cid> <json> <success-msg> <fail-reason>: PATCH the resolved card via the shared
# kb_api, which captures the HTTP status in KB_HTTP (the status-capture the hand-rolled
# `curl -fsS` here used to drop, #4337 — a 403 token-scope failure and a 422 were both a bare
# rc 22). On a 2xx, echo <success-msg> to stderr; on any failure, durably record <fail-reason>
# plus the status via kb_bcs_log (this hook never sets KB_LOG_FILE, so KB_BCS_LOG is its durable
# surface). Fail-soft: always returns 0 — a failed board write must never block a checkout.
# Reads KB_API / KB_TOKEN (pinned once above, before the first call).
_bcs_patch() {
    local cid="$1" json="$2" okmsg="$3" failreason="$4"
    if kb_api PATCH "/tasks/$cid.json" "$json" >/dev/null 2>&1; then
        [ -n "$okmsg" ] && printf '%s\n' "$okmsg" >&2
        return 0
    fi
    kb_bcs_log "$failreason (HTTP ${KB_HTTP:-?})"
    return 0
}

# Card-id extraction, split into two pure (network-free, sourceable) matchers so the
# grammar itself is unit-testable (tests/board-card-start-selftest.sh) rather than only
# reachable through the network-driving main body. They mirror the two-tier fallback the
# main body walks: an explicit named-card token first, then a typed-branch leading id.

# _bcs_explicit_card_id <branch>: the explicit named-card grammar, at a token boundary,
# >=2 digits. `card<N>` (the separator after `card` is OPTIONAL — so the natural, most-
# typed glued spelling `card4524` correlates, not only `card-4524` / `card/4524` /
# `card#4524`), or a bare `#N`. Echoes the zero-stripped id, or nothing. The `_` in the
# leading boundary is NOT accepted as the card separator (`card_4524` stays a lint case,
# card-4621) — only `#`, `-`, `/`, or glued.
_bcs_explicit_card_id() {
    printf '%s\n' "${1:-}" | grep -oiE '(^|[/_-])(card[-/#]?|#)0*[0-9]{2,}' | grep -oE '[0-9]+' | head -1 | sed 's/^0*//'
}

# _bcs_typed_card_id <branch>: a typed-branch leading id — a known type prefix, a slash,
# an optional `#`, then a >=3-digit id, token-bounded (so `feat/2signup`, a 2-digit
# version, or a `dl-189` token can't match). Echoes the id, or nothing.
_bcs_typed_card_id() {
    printf '%s\n' "${1:-}" \
        | grep -oiE '^(feat|feature|fix|hotfix|bug|chore|fr|refactor|perf|docs|ci|test|build|style)/#?0*[0-9]{3,}([/_-]|$)' \
        | grep -oE '[0-9]{3,}' | head -1 | sed 's/^0*//'
}

# _bcs_branch_lint_warning <branch>: fail-soft ADVISORY for the pre-push hook (card-4621).
# Empty (no warning) when the branch already carries a token the auto-move grammar
# recognizes — a DL, an explicit card id, or a typed leading id — OR when there is no
# card-ish signal at all. It warns ONLY on the narrow, high-precision residual: the literal
# `card`/`#` at a token boundary followed by >=2 digits through a separator the grammar does
# NOT accept (e.g. `card_4524`, `card.4524`) — an unmistakable "meant a card, won't correlate"
# case. Echoes a one-line hint at the compliant spelling; never blocks a push.
_bcs_branch_lint_warning() {
    local branch="${1:-}"
    [ -n "$branch" ] || return 0
    # Already correlates → nothing to warn about.
    [ -n "$(printf '%s\n' "$branch" | grep -oiE 'dl-?[0-9]+' | head -1)" ] && return 0
    [ -n "$(_bcs_explicit_card_id "$branch")" ] && return 0
    [ -n "$(_bcs_typed_card_id "$branch")" ] && return 0
    # `card`/`#` at a boundary + a separator OUTSIDE the accepted set (`-` `/` `#` glued) + digits.
    local id
    id="$(printf '%s\n' "$branch" | grep -oiE '(^|[/_-])(card|#)[^a-z0-9/#-]0*[0-9]{2,}' | grep -oE '[0-9]+' | head -1 | sed 's/^0*//')"
    [ -n "$id" ] || return 0
    printf "branch '%s' looks like it references card %s, but the board auto-move grammar won't recognize this spelling — the card will NOT move to In Progress on checkout. Rename it e.g. 'fix/card-%s-slug' (or 'fix/%s-slug').\n" "$branch" "$id" "$id" "$id"
}

# When sourced (tests/board-card-start-selftest.sh), expose only the pure helpers above and
# stop here — sourcing must not run the checkout mover.
(return 0 2>/dev/null) && return 0

# `--lint <branch>`: the pre-push advisory path — print the branch-name warning (if any)
# and exit, without any board/network work. Fail-soft like every other exit here.
lint_mode=0
if [ "${1:-}" = "--lint" ]; then lint_mode=1; shift; fi

branch="${1:-$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)}"
[ -n "$branch" ] && [ "$branch" != "HEAD" ] || exit 0

if [ "$lint_mode" = 1 ]; then
    warning="$(_bcs_branch_lint_warning "$branch")"
    [ -n "$warning" ] && printf 'board-branch-lint: %s\n' "$warning" >&2
    exit 0
fi

# DL token from the branch name (case-insensitive); kb_dl_num strips zeros and
# rejects a non-DL, so a malformed token degrades to the card-id path below.
dltok="$(printf '%s\n' "$branch" | grep -oiE 'dl-?[0-9]+' | head -1 || true)"
dl=""
[ -n "$dltok" ] && dl="$(kb_dl_num "$dltok" 2>/dev/null || true)"

# Card-id token — ALWAYS extracted (framework contract #112): a DL that resolves
# to no card falls through to the card-id path, so the native id must be available
# even when a DL token is also present. Extraction is card-id-specific (an explicit
# `card4524` / `card-2950` / `card/2950` / `#2950`, or a typed branch's leading
# >=3-digit id directly after a known type prefix, token-bounded so `feat/2signup`,
# a 2-digit version, or a `dl-189` token can't match), so it never mis-reads a DL as
# a card id. See _bcs_explicit_card_id / _bcs_typed_card_id for the two tiers.
cid_explicit=0
cid_token="$(_bcs_explicit_card_id "$branch")"
[ -n "$cid_token" ] && cid_explicit=1   # matched the explicit card#N / #N grammar (a named card)
[ -n "$cid_token" ] || cid_token="$(_bcs_typed_card_id "$branch")"

[ -n "$dl" ] || [ -n "$cid_token" ] || exit 0

command -v curl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1 || bcs_skip "curl and jq are both required but not both on PATH"

# Board id + API base.
#   board_id: a repo-local UNCOMMITTED `git config kanban.board-id` (#4290) FIRST, else the
#   repo's committed .release-pr.json .promote.board_id. git config wins because the board id
#   now SELECTS A CREDENTIAL (the per-board token below), which makes it a trust decision, and
#   only the host-local value is beyond the reach of a PR. The committed value stays a
#   fallback (release repos carry it) but is digits-validated before use. In practice the two
#   are mutually-exclusive populations — a release repo has the committed file, a non-release
#   repo has the git config — so the order rarely decides anything; it is the per-board-token
#   gate below, not this order, that actually bounds the credential.
#   The board id is not a secret; api_base still resolves from ~/.kanban-host.env below, so
#   neither source adds a committed token surface. A repo unrelated to any board sets neither
#   and the hook no-ops.
#   api_base: the committed value — EXCEPT it is usually a host-scrubbed RFC-2606/6761
#   placeholder (the real kanban host must not live in a repo, bridge #218 / toolkit host-scrub),
#   or absent entirely (a non-release repo). In either case fall back to $KB_API — the real host
#   resolved from ~/.kanban-host.env (KBCARD_API) via kb_load_host_env below — so the hook
#   reaches the real board with NO per-repo config. A genuinely real committed host is used as-is.
root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[ -n "$root" ] || bcs_skip "not inside a git work tree (cannot resolve the repo root)"
cfg="$root/.release-pr.json"
board=""; committed_api=""; board_src=""
[ -r "$cfg" ] && committed_api="$(jq -r '.promote.api_base // empty' "$cfg" 2>/dev/null)"
board="$(git config --get kanban.board-id 2>/dev/null | grep -oE '[0-9]+' | head -1 || true)"
if [ -n "$board" ]; then
    board_src="hostlocal"
elif [ -r "$cfg" ]; then
    # Anchored ^[0-9]+$ (not a substring scan): this value is committed and PR-editable, and it
    # keys the board-env lookup below.
    board="$(jq -r '.promote.board_id // empty' "$cfg" 2>/dev/null | grep -oE '^[0-9]+$' | head -1 || true)"
    [ -n "$board" ] && board_src="committed"
fi
[ -n "$board" ] || bcs_skip "no board_id — run 'git config kanban.board-id <id>' in this repo, or set .promote.board_id in .release-pr.json (docs/INSTALL.md)"

# Host env → KB_API + KB_HOST_TOKEN_FILE (the host-level token default). Cannot fail; the
# token itself is read below, once the board env is known.
kb_load_host_env

# The board env for THIS board, resolved ONCE — it supplies both the stage ids and (when
# allowed) the per-board token. It is only ever sourced inside kb_board_env_* subshells, so
# it can never move KANBAN_EXPECTED_HOST before the https-host guard that reads it below.
board_envf="$(kb_board_env_for "$board" || true)"

# Per-board token — ONLY when the board id came from the host-local git config. A committed
# .release-pr.json is PR-editable, so honoring it here would let a PR re-point the hook at
# another board's env and send THAT board's token; a committed board id therefore keeps the
# host/default token, exactly as before this change. Per-board tokens are an explicit
# host-local opt-in. (Inverting the board_id order alone would NOT have closed this: the two
# sources are mutually-exclusive populations, so the inversion only ever helps the population
# that never had the exposure — the gate is the real fix.)
board_tok=""
if [ "$board_src" = "hostlocal" ] && [ -n "$board_envf" ]; then
    IFS= read -r board_tok <<<"$(kb_board_env_get "$board_envf" KBCARD_TOKEN_FILE)"
fi
# Reads the token into memory only (not sent until the guarded curls below). MUST stay
# `|| bcs_skip`: unguarded, an unreadable token leaves KB_TOKEN unset and `set -u` aborts the
# next line — and the installed hook wrapper discards stderr, so that reads as a silent dead
# hook with no durable log entry.
kb_read_token "${board_tok:-${KB_HOST_TOKEN_FILE:-$HOME/.kanban-dev-token}}" \
    || bcs_skip "kanban token file not readable: ${board_tok:-${KB_HOST_TOKEN_FILE:-$HOME/.kanban-dev-token}} (create ~/.kanban-host.env; see docs/INSTALL.md)"
token="$KB_TOKEN"

# Effective api_base: the committed value, unless it is a documentation-placeholder host
# (host-scrubbed) or absent (committed_api empty — a non-release repo) — then the host-env-
# resolved KB_API is the real one. _bcs_is_placeholder_host recognizes the RFC-2606/6761
# reserved forms the scrub may emit (example.{com,net,org}, .invalid, .test, .localhost, the
# bare .example TLD), anchored so a real host that merely contains such a substring is not
# misread (#34); empty committed_api is treated as "placeholder" so it falls back to KB_API.
api="$committed_api"
if _bcs_is_placeholder_host "$api"; then
    api="${KB_API:-}"
fi
if [ -z "$api" ]; then
    bcs_skip "no usable kanban api_base — committed .release-pr.json is host-scrubbed/absent and \$KBCARD_API is unset (create ~/.kanban-host.env; see docs/INSTALL.md)"
fi

# Guard the api_base before sending the token — a malicious .release-pr.json edit (or
# host-env value) must not exfiltrate the token to an untrusted host (#3570). Fail-SOFT
# (exit 0 — this runs from a post-checkout hook and must NEVER block a checkout) but
# LOUD on stderr; the token is simply never sent when the host isn't trusted.
kb_require_https_host "$api" || bcs_skip "api_base '$api' failed the https-host trust guard (KANBAN_EXPECTED_HOST)"

# The card read + the two writes below go through the shared kb_api / kb_api_status, which
# resolve the host and bearer from KB_API / KB_TOKEN. api is the effective base resolved+guarded
# above; KB_TOKEN is already this board's token (kb_read_token set it), but pin both explicitly
# so the shared callers can't reach for a stale ambient value.
KB_API="$api"; KB_TOKEN="$token"

# Stage ids for THIS board, from the SAME board env resolved above (a second matcher here
# was free to pick a different file than the token's on a duplicate KB_BOARD_ID), via the
# shared reader — so the ids get the same clean-slate read as the token: a key this env does
# not set comes back EMPTY rather than inheriting another board's exported value.
# Scope of that, honestly: stage ids are unique to one board, so a foreign id simply never
# matches this board's cards — the reachable case is a board env MISSING a required key,
# where the guard below would pass on an inherited id and the PATCH would then name a stage
# that isn't on this board. Empty is the correct answer, and it fail-softs at the guard.
inprog=""; backlog=""; prioritized=""; held=""
if [ -n "$board_envf" ]; then
    { IFS= read -r inprog; IFS= read -r backlog; IFS= read -r prioritized; IFS= read -r held; } \
        <<<"$(kb_board_env_get "$board_envf" KB_STAGE_IN_PROGRESS KB_STAGE_BACKLOG KB_STAGE_PRIORITIZED KB_STAGE_HELD)"
fi
# Held is optional (a board may not have the column); backlog/prioritized/in_progress
# are required for any promotion to make sense.
[ -n "$inprog" ] && [ -n "$backlog" ] && [ -n "$prioritized" ] || bcs_skip "no ~/.kanban-*-board.env has KB_BOARD_ID=$board with in-progress/backlog/prioritized stage ids"

# A branch CREATION is the genuine work-start signal for a Held card (contract
# PR #113); a re-checkout of an existing branch must not un-park it. The branch's
# reflog records `branch: Created from …` exactly once at creation and it stays the
# LAST entry (commits/checkouts prepend). On `git switch -c` the post-checkout hook
# fires with that entry ~0s old; a later re-checkout sees it aged. A fresh clone
# landing on an existing branch logs `clone: …`, which does not match — so cloning
# can't un-park. Fail-soft: no reflog / unparsable timestamp → NOT a creation.
branch_just_created() {
    local last ts age
    last="$(git reflog show --date=unix "$branch" 2>/dev/null | tail -1)" || return 1
    printf '%s' "$last" | grep -q 'branch: Created from' || return 1
    ts="$(printf '%s' "$last" | grep -oE '@\{[0-9]+\}' | tr -d '@{}')"
    [ -n "$ts" ] || return 1
    age=$(( $(date +%s) - ts ))
    [ "$age" -ge 0 ] && [ "$age" -le "${KB_HELD_CREATE_MAX_AGE:-15}" ]
}

# Resolve the card (task) id to move — try-in-order-with-fallback (framework #112):
# resolve on the OUTCOME of a token, not its presence. via_cardid records that the
# card was selected by native id (the stamp step below keys on it).
via_cardid=0
if [ -n "$dl" ]; then
    # Whole-board paginated fetch (fix: was page-1 only, so a DL beyond page 1 was
    # missed). Match NUMERICALLY on the dl_number's digits so every stored form —
    # "DL-093" (legacy 3-pad), "DL-0156" (canonical), or a bare 156 — resolves.
    cards="$(fetch_board_cards "$api" "$token" "$board")" || bcs_skip "board $board fetch failed (unreachable or auth rejected)"
    cid="$(printf '%s' "$cards" | jq -r --argjson want "$dl" '
        [ .[]
          | (.payload.dl_number // empty) as $raw
          | ($raw | tostring) as $s
          | select($s | test("[0-9]"))
          | select(($s | capture("(?<n>[0-9]+)").n | tonumber) == $want)
          | .id ] | .[0] // empty' 2>/dev/null)"
    if [ -n "$cid" ]; then
        # (1)/(3) DL resolved → it wins. A co-present card-id token is ignored (loud).
        label="DL-$dl"
        [ -n "$cid_token" ] && [ "$cid_token" != "$cid" ] \
            && echo "board-card-start: branch names DL-$dl (card #$cid) and #$cid_token — DL wins; #$cid_token ignored" >&2
    elif [ -n "$cid_token" ]; then
        # (2) DL tracks no card yet (the unstamped-card class) → fall through to the
        # card-id path instead of dead-ending. The stamp step below writes dl_number.
        cid="$cid_token"; label="#$cid_token"; via_cardid=1
        echo "board-card-start: DL-$dl matches no card — falling through to #$cid_token (framework #112)" >&2
    else
        # (4) DL present, unresolved, no card-id fallback → a high-value miss (a
        # decision-logged-but-unstamped card). Loud, never a silent no-op.
        bcs_skip "branch names DL-$dl but no card carries that dl_number and there is no card-id fallback token"
    fi
else
    cid="$cid_token"
    label="#$cid_token"
    via_cardid=1
fi
[ -n "$cid" ] || bcs_skip "internal: no card id resolved after a token match"

# Fetch the card; read its current stage AND board. The board-match guard bounds
# the card-id path — a bare number can only move a card on the repo's own board.
# kb_api_status returns "<http>\n<body>" and always yields a clean status (a curl transport
# failure → "000"), so the caller can still tell a 404 (no such card) from a 401/403 (bad/scoped
# token) from an unreachable host — the distinction the local `-fsS` read would have collapsed.
resp="$(kb_api_status GET "/tasks/$cid.json")"
http="${resp%%$'\n'*}"
card="${resp#*$'\n'}"
if [ "$http" != "200" ]; then
    # Attribute the failure to its ACTUAL cause. Only a 404 means the card isn't there.
    case "$http" in
        404) ;;   # fall through to the not-a-card handling below
        000) bcs_skip "card #$cid could not be read — the kanban API at $api is unreachable; the card was NOT confirmed missing" ;;
        401|403) bcs_skip "card #$cid could not be read — the kanban API rejected the token from ${KB_TOKEN_FILE:-?} (HTTP $http); the card was NOT confirmed missing" ;;
        *) bcs_skip "card #$cid could not be read — the kanban API returned HTTP $http; the card was NOT confirmed missing" ;;
    esac
fi
cur="$(printf '%s' "$card" | jq -r '.data.workflow_stage_id // empty' 2>/dev/null)"
cbd="$(printf '%s' "$card" | jq -r '.data.board_id // empty' 2>/dev/null)"
if [ -z "$cur" ]; then
    # The resolved id is not a real card (a 404, or a 200 whose body has no stage). For a DL
    # path this is unreachable (the fetch was board-scoped and matched); for the card-id path
    # the branch's number is not a card. Loud ONLY when the branch NAMED a card explicitly
    # (card#N / #N) — a genuine miss; the implicit typed-branch leading id (often a foreign
    # ticket number, a routine false positive) is silent.
    [ "${cid_explicit:-0}" = 1 ] && bcs_skip "card #$cid named in the branch does not exist"
    exit 0
fi
if [ "$cbd" != "$board" ]; then
    # Designed SILENT scope guard (see header): a card-id number that lives on ANOTHER board is
    # a deliberate no-op — a stray number must not promote an unrelated task. A routine correct
    # outcome, never a failure, so never loud (that would train agents to ignore hook output).
    exit 0
fi

# Opt-out (framework contract, agent-board-framework PR #113): a card a human has
# pinned — a non-empty block_reason OR a `no-automove` tag — is NEVER auto-moved,
# regardless of stage. Loud refusal so the skipped move is visible.
breason="$(printf '%s' "$card" | jq -r '.data.block_reason // empty')"
sticky="$(printf '%s' "$card" | jq -r 'any((.data.tags // [])[]; . == "no-automove")')"
if [ -n "$breason" ] || [ "$sticky" = "true" ]; then
    bcs_skip "card #$cid ($label) is pinned (block_reason/no-automove) — auto-move refused"
fi

# Stamp the dl_number write-site (framework contract #112 step 2). When the card
# was selected by native id AND the branch also names a DL, write payload.dl_number
# so the downstream DL-correlated movers (bridge writeback, release promote) stop
# no-op'ing on this card — the failure that stranded the #2179 class. if-empty only:
# never overwrite a differing stamp (loud warn). The kanban API MERGES payload
# per-key (#2180), so PATCH only {dl_number} — the other custom fields are left as-is
# (and a concurrent edit to them survives, which read-merge-write would clobber). Runs
# regardless of the stage-gate below (a card past the move stages still needs the
# stamp), but AFTER the pinned/opt-out guard — a hands-off card gets no automated
# write at all. Fail-soft — never blocks.
if [ "$via_cardid" = 1 ] && [ -n "$dl" ]; then
    curdl="$(printf '%s' "$card" | jq -r '.data.payload.dl_number // empty' 2>/dev/null)"
    curdl_num="$(printf '%s' "$curdl" | grep -oE '[0-9]+' | head -1 | sed 's/^0*//')"
    if [ -z "$curdl" ]; then
        want="$(kb_dl_canon "$dl" 2>/dev/null || true)"
        if [ -n "$want" ]; then
            _bcs_patch "$cid" "$(jq -nc --arg dl "$want" '{payload: {dl_number: $dl}}')" \
                "board-card-start: card #$cid stamped payload.dl_number=$want (was unstamped; DL-$dl named in branch)" \
                "card #$cid dl_number stamp (=$want) failed"
        fi
    elif [ "$curdl_num" != "$dl" ]; then
        echo "board-card-start: card #$cid has dl_number=$curdl but branch names DL-$dl — NOT overwriting (stamp conflict)" >&2
    fi
fi

# Promote-from policy (contract PR #113):
#   - Backlog / Prioritized → promote on any branch checkout (unchanged: a
#     never-worked card advancing on a checkout is the intended work-start signal).
#   - Held → promote ONLY on a genuine branch CREATION. Re-checking-out an existing
#     branch onto a Held card is a deliberate no-op — the original re-fire
#     protection the manual-only default guaranteed. `branch_just_created` reads the
#     branch's own reflog (fail-soft: no reflog / unparsable → not-a-creation).
#   - Anything else (In Progress / In Review / Shipped / Released / Won't-Do) →
#     never touched.
case "$cur" in
    "$backlog" | "$prioritized") ;;
    "$held")
        # Reached only when cur == held (a non-empty stage id); promote only on a
        # genuine creation, else leave the parked card put.
        branch_just_created || exit 0
        ;;
    *) exit 0 ;;
esac

_bcs_patch "$cid" "$(jq -nc --argjson s "$inprog" '{workflow_stage_id: $s}')" \
    "board-card-start: card #$cid ($label) → In Progress" \
    "card #$cid ($label) → In Progress move failed"
exit 0
