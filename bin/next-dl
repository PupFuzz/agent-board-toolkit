#!/usr/bin/env bash
# next-dl — mint the next DL-NNN for a project's decision log.
#
# Two modes:
#
#   DEFAULT (atomic claim, DL-157): when the board's kanban exposes the
#   `dl-sequence/claim` endpoint, next-dl ATOMICALLY claims the next number
#   server-side (race-free across concurrent allocators). A claim RESERVES the
#   number — an unused claim simply burns it (gaps are expected and fine). If the
#   endpoint is absent (older kanban / not deployed) or unreachable, it falls
#   back SILENTLY to the offline max+1 scan below — so behaviour is unchanged
#   until the endpoint ships.
#
#   --peek: skip the endpoint and return max+1 WITHOUT reserving (the original,
#   non-consuming behaviour) — use it to just see the next number.
#
# The offline max+1 scan takes the max over BOTH:
#   (1) `## DL-NNN` headers in CLAUDE_DECISIONS.md across every local checkout
#       (so an in-flight DL on a worktree / held PR can't be reused), AND
#   (2) the project's kanban board's stamped `dl_number`s, when reachable.
# (2) closes the collision gap that caused the DL-154 reuse (board card #2643).
# The board check is FAIL-SOFT — an unreachable board/token/API warns and falls
# back to the header scan, never blocking allocation offline. NOTE: the offline
# path is NOT atomic — safe for single-stream allocation; concurrent allocators
# on a shared board need the claim endpoint (the default) to avoid duplicates.
#
# Usage: next-dl kanban|bridge|--board <name> [--peek]   (--board: an arbitrary PM-project board)
set -euo pipefail

USAGE='usage: next-dl kanban|bridge|--board <name> [--peek]'
peek=0
project=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --peek|--no-claim) peek=1 ;;
        --board)   # FR-2: an arbitrary PM-project board, not just kanban|bridge
            shift; [[ -n "${1:-}" && -z "$project" ]] || { echo "$USAGE" >&2; exit 2; }
            project="$1" ;;
        kanban|board|kanban-board|bridge|agent-bridge)
            [[ -z "$project" ]] || { echo "$USAGE" >&2; exit 2; }
            project="$1" ;;
        *) echo "$USAGE" >&2; exit 2 ;;
    esac
    shift
done
[[ -n "$project" ]] || { echo "$USAGE" >&2; exit 2; }

# Per-project defaults (back-compat). An arbitrary --board <name> resolves its
# board env by the `~/.kanban-<name>-board.env` convention and has no built-in
# offline checkout glob — supply it via KB_DL_CHECKOUT_GLOBS (see below).
case "$project" in
    kanban|board|kanban-board)
        default_patterns=("$HOME/kanbanboard" "$HOME/kanbanboard-*")
        board_env="${KBCARD_BOARD_ENV:-$HOME/.kanban-dev-board.env}" ;;
    bridge|agent-bridge)
        default_patterns=("$HOME/agent-webhook-bridge-*")
        board_env="${KBCARD_BOARD_ENV:-$HOME/.kanban-bridge-board.env}" ;;
    *)
        default_patterns=()
        board_env="${KBCARD_BOARD_ENV:-$HOME/.kanban-${project}-board.env}" ;;
esac

# Offline checkout globs (FR-2): the offline `max+1` header scan reads
# `## DL-NNN` from CLAUDE_DECISIONS.md across these checkouts. KB_DL_CHECKOUT_GLOBS
# (comma-separated patterns; leading `~` expanded) OVERRIDES the per-project
# default so a PM-project adopter's own repos are scanned. The primary atomic-claim
# path is board-config-driven and needs none of this.
patterns=("${default_patterns[@]}")
if [[ -n "${KB_DL_CHECKOUT_GLOBS:-}" ]]; then
    IFS=',' read -r -a patterns <<<"$KB_DL_CHECKOUT_GLOBS"
fi
globs=()
for pat in "${patterns[@]}"; do
    pat="${pat/#\~/$HOME}"
    # shellcheck disable=SC2206  # deliberate glob/word-split of a config-supplied pattern
    expanded=($pat)
    for d in "${expanded[@]}"; do [[ -e "$d" ]] && globs+=("$d"); done
done

# Highest DL number found in a stream of text on stdin (tolerates any DL-NNN form).
max_dl() { grep -oE 'DL-[0-9]+' | grep -oE '[0-9]+' | sed 's/^0*//;s/^$/0/' | sort -n | tail -1; }

# Resolve api/board/token from config (sourced in a subshell so env never leaks
# into this script). Echoes "<api>\t<board>\t<token_file>"; non-zero (with a
# reason on stderr) if curl/jq or any config is missing.
resolve_board_cfg() (
    command -v curl >/dev/null && command -v jq >/dev/null \
        || { echo "next-dl: curl/jq missing — skipping board check" >&2; exit 1; }
    [[ -r "$board_env" ]] || { echo "next-dl: $board_env unreadable — skipping board check" >&2; exit 1; }
    # shellcheck disable=SC1090
    source "$board_env"
    host_env="${KANBAN_HOST_ENV:-$HOME/.kanban-host.env}"
    if [[ -z "${KBCARD_API:-}" && -r "$host_env" ]]; then
        # shellcheck disable=SC1090
        source "$host_env"
    fi
    api="${KBCARD_API:-}"; board="${KB_BOARD_ID:-}"
    token_file="${KBCARD_TOKEN_FILE:-$HOME/.kanban-dev-token}"
    [[ -n "$api" && -n "$board" && -r "$token_file" ]] \
        || { echo "next-dl: board config incomplete — skipping board check" >&2; exit 1; }
    printf '%s\t%s\t%s' "$api" "$board" "$token_file"
)

# Atomic server-side claim (DL-157). Echoes the claimed integer on success.
# Exit code tells the caller HOW it failed, so a real endpoint error isn't masked
# as "absent" (the bug that made AIMLA misdiagnose a deployed endpoint as missing):
#   0 → claimed (positive integer on stdout).
#   1 → endpoint ABSENT (HTTP 404) or unreachable / no config — benign during rollout;
#       caller falls back silently to the offline max+1 scan.
#   3 → endpoint PRESENT but the claim FAILED (any non-2xx other than 404, or a 2xx
#       with no positive value) — surfaced loudly here; the caller MUST abort rather
#       than silently mint via the non-atomic offline scan (which could re-mint on a
#       shared board and hides the real cause: token board-membership, board id, api_base).
# No -f on curl: we need the status to tell 404-absent from a present-but-errored claim.
board_claim() (
    cfg="$(resolve_board_cfg 2>/dev/null)" || exit 1
    IFS=$'\t' read -r api board token_file <<<"$cfg"
    resp="$(curl -sS -w $'\n%{http_code}' -X POST \
        -H "Authorization: Bearer $(cat "$token_file")" -H "Accept: application/json" \
        "$api/boards/$board/dl-sequence/claim.json" 2>/dev/null)" || exit 1   # connection failure → benign fallback
    http="${resp##*$'\n'}"; body="${resp%$'\n'*}"
    case "$http" in
        2[0-9][0-9])
            val="$(printf '%s' "$body" | jq -r '.data.value // empty' 2>/dev/null || true)"
            [[ "$val" =~ ^[0-9]+$ && "$val" -ge 1 ]] || exit 1   # 2xx but no positive value → benign fallback
            printf '%s' "$val" ;;
        404) exit 1 ;;   # endpoint not deployed — benign; fall back to the offline scan
        *)
            echo "next-dl: the atomic claim endpoint is PRESENT but FAILED (HTTP $http) — NOT silently falling back to the non-atomic offline scan. Fix the cause (token board-membership? board id? api_base?) and retry. Response: $(printf '%s' "$body" | tr '\n' ' ' | head -c 300)" >&2
            exit 3 ;;
    esac
)

# DEFAULT: prefer the atomic claim. Fall back to the offline peek ONLY when the
# endpoint is genuinely absent/unreachable (exit 1, the rollout case). A claim that
# FAILED against a PRESENT endpoint (exit 3) is surfaced by board_claim and aborts
# here — silently degrading to the non-atomic scan is what masked AIMLA's real error.
if [[ $peek -eq 0 ]]; then
    if claimed="$(board_claim)"; then crc=0; else crc=$?; fi
    if [[ $crc -eq 0 && "$claimed" =~ ^[0-9]+$ ]]; then
        printf 'DL-%03d\n' "$claimed"
        exit 0
    fi
    [[ $crc -eq 3 ]] && exit 1   # endpoint present but errored → already surfaced; do NOT mint via the racy scan
fi

# Offline / --peek path: max+1 over local headers + board-stamped dl_numbers.
max=0

# (1) local CLAUDE_DECISIONS.md headers across all checkouts.
for d in "${globs[@]}"; do
    f="$d/CLAUDE_DECISIONS.md"
    [[ -f "$f" ]] || continue
    n="$(grep -oE '^## DL-[0-9]+' "$f" 2>/dev/null | max_dl)"
    [[ -n "$n" && "$n" -gt "$max" ]] && max="$n"
done

# (2) board-stamped dl_numbers (fail-soft).
board_dl_max() (
    cfg="$(resolve_board_cfg)" || exit 1
    IFS=$'\t' read -r api board token_file <<<"$cfg"
    tok="$(cat "$token_file")"
    # PAGINATE the whole board so the fallback seed sees the TRUE max, not a truncated
    # page 1 (the board-snapshot #3369 / kbcard #3091 defect — this was the last copy
    # still page-1-only). dl_numbers accumulate via STDIN (no argv). Refuse (exit 2)
    # ONLY if a page read fails — an incomplete scan could re-mint a used DL. NB: even a
    # complete paginated scan is NON-ATOMIC; the atomic claim endpoint is the real fix
    # on a shared board (this path is reached only when that endpoint is absent).
    page=1; last_page=1; nums=""
    while :; do
        resp="$(curl -fsS -H "Authorization: Bearer $tok" -H "Accept: application/json" \
            "$api/tasks/search.json?q=board_id=$board&limit=200&page=$page" 2>/dev/null)" \
            || { [[ "$page" -eq 1 ]] && { echo "next-dl: board unreachable — skipping board check" >&2; exit 1; }
                 echo "next-dl: board read failed on page $page of a multi-page board — refusing to mint from a truncated scan (could re-mint a used DL)" >&2; exit 2; }
        [[ "$page" -eq 1 ]] && last_page="$(printf '%s' "$resp" | jq -r '.meta.last_page // 1')"
        nums+="$(printf '%s' "$resp" | jq -r '.data[]?.payload.dl_number // empty')"$'\n'
        [[ "$page" -ge "${last_page:-1}" ]] && break
        page=$((page + 1))
        [[ "$page" -gt "${NEXT_DL_PAGE_CAP:-50}" ]] && { echo "next-dl: board exceeds NEXT_DL_PAGE_CAP=${NEXT_DL_PAGE_CAP:-50} pages — refusing to mint from a partial scan" >&2; exit 2; }
    done
    printf '%s' "$nums" | max_dl
)
# Exit-code convention: 2 = incomplete read (a page fetch failed mid-pagination) ⇒ fail
# loud, do not stamp (undercount could re-mint). 1 = board unreachable on page 1 / no
# board configured ⇒ keep the original fail-soft posture (empty bmax ⇒ mint from the
# local sources below).
# The `if` form is set -e-safe (a non-zero command substitution in a bare
# assignment would otherwise exit before $? is captured).
if bmax="$(board_dl_max)"; then dlrc=0; else dlrc=$?; fi
[[ "$dlrc" -eq 2 ]] && exit 1
[[ "$bmax" =~ ^[0-9]+$ && "$bmax" -gt "$max" ]] && max="$bmax"

[[ "$max" -eq 0 ]] && { echo "next-dl: no DL headers found for '$project' — check the checkout paths" >&2; exit 1; }
printf 'DL-%03d\n' "$((max + 1))"
