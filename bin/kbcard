#!/usr/bin/env bash
# kbcard — thin wrapper for the kanban-board production board API
# Lives outside the kanbanboard repo. Token path + board state live in
# ~/.kanban-dev-token and ~/.kanban-dev-board.env so the script is portable.
#
# Usage:
#   kbcard create-card --type <alias> --name "title" \
#                      --column backlog|prioritized|in_progress|in_review|held|shipped_to_dev|released_to_main|wont_do \
#     <alias> is config-driven: any KB_TYPE_<ALIAS> in the board env writes that
#     native card_type_id; an unset/`000` alias (or KB_TYPING_MODE=tags) instead
#     omits card_type_id and tags the card `type:<alias>` — so create-card/list work
#     on native, all-tag, and mixed boards alike.
#                      [--description "..."] [--tags "tag1,tag2"] [--external-id 12345] \
#                      [--dl "DL-093"] [--pr 178] [--pr-url URL] [--version "v0.9.2"] [--origin preemptive|consumer-driven|incident-triggered|user-requested] [--triaged]
#     --triaged tags the card `triaged` at birth (symmetric with `patch --triaged`)
#     so a plain PM-minted card isn't a false-positive untriaged next session.
#   kbcard move --task ID-OR-EXT --column COLUMN
#   kbcard patch --task ID-OR-EXT [--pr N] [--pr-url URL] [--version VER] [--column COL] [--description "..."] [--dl DL-NNN] [--triaged]
#     --pr-url writes payload.pr_url — the kanban derives a card's by-ref `source` (owner/repo)
#     from it; required for the repo-qualified PR→card lookup on a multi-repo board (--pr alone
#     sets pr_number, not source). Pre-PR placeholder: https://github.com/<owner>/<repo>/pull/0
#   kbcard list  [--column COL] [--type TYPE]
#   kbcard link --from TASK --to TASK --relation "bundles"|"blocks"|"caused"
#   kbcard show --task ID-OR-EXT
#   kbcard archive --task ID-OR-EXT [--dry-run]
#     Take the card off the board without deleting it (PATCH _action:archive) —
#     the row stays live + recoverable and keeps its stable id + dl_number.
#   kbcard delete --task ID-OR-EXT [--hard] [--yes|-y] [--dry-run]
#     Default: soft-delete (trashed, recoverable within the retention window; RETAINS
#     dl_number). --hard: permanent force-delete (cascades subtasks/comments/links;
#     RELEASES dl_number; two-step soft-then-force). --hard prompts to confirm unless
#     --yes, and refuses without --yes in a non-interactive shell. --dry-run prints
#     the exact API calls without executing them.
#
# Source of truth for IDs:
#   ~/.kanban-dev-board.env — sourced for stage/type/cf ID lookups.

set -euo pipefail

# Shared toolkit lib (config resolution, API wrapper, pagination, DL canon).
KB_LIB="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/_kb-board-lib.sh"
[ -r "$KB_LIB" ] || { echo "$(basename "${BASH_SOURCE[0]}"): shared lib _kb-board-lib.sh not found next to this script — reinstall per INSTALL.md §3 (symlink all of bin/), or vendor _kb-board-lib.sh alongside this tool." >&2; exit 1; }
# shellcheck source=bin/_kb-board-lib.sh
source "$KB_LIB"

# kb_api knobs: own message prefix, the failure log, and echo the error body.
KB_PROG="kbcard"
KB_LOG_FILE="${KBCARD_LOG_FILE:-$HOME/.kbcard-failures.log}"
KB_API_ERRBODY=1
# fetch_board_cards (cmd_list) must report + log a page-fetch failure loudly like
# every other kbcard subcommand — not exit silently. KB_LOG_FILE above is the sink.
KB_FETCH_LOUD=1

# Config (board env + host env + token) is resolved in main() once the optional
# `--board NAME` global flag is parsed, via kb_load_config. Card types are
# per-board: `native_type_id` resolves a `--type` alias to KB_TYPE_<ALIAS> from
# the board env (any alias), writing the native id when present and falling back
# to a `type:<alias>` tag when the board lacks that native type — so an alias
# absent on one board (`fr` on kanban, `request`/`idea` on bridge) is tagged, not
# rejected. (`stage_id` still rejects an unknown column — stages are required.)
# API base is board-independent and NOT baked in — kb_load_config reads it from
# ~/.kanban-host.env (override via $KANBAN_HOST_ENV); see docs/INSTALL.md.

stage_id() {
    local id
    case "$1" in
        backlog) id="${KB_STAGE_BACKLOG:-}" ;;
        prioritized) id="${KB_STAGE_PRIORITIZED:-}" ;;
        in_progress) id="${KB_STAGE_IN_PROGRESS:-}" ;;
        in_review) id="${KB_STAGE_IN_REVIEW:-}" ;;
        held) id="${KB_STAGE_HELD:-}" ;;
        shipped_to_dev) id="${KB_STAGE_SHIPPED_TO_DEV:-}" ;;
        released_to_main) id="${KB_STAGE_RELEASED_TO_MAIN:-}" ;;
        wont_do) id="${KB_STAGE_WONT_DO:-}" ;;
        *) echo "kbcard: unknown column '$1'" >&2; return 2 ;;
    esac
    [[ -z "$id" ]] && { echo "kbcard: column '$1' is not defined on this board" >&2; return 2; }
    echo "$id"
}
# Reverse of stage_id: the column NAME for a native stage id, from whatever
# KB_STAGE_* vars the sourced board env defines (any of them, not just the eight
# stage_id aliases — a board's own taxonomy resolves too). Prints the lowercased
# suffix (KB_STAGE_SHIPPED_TO_DEV=51 → "shipped_to_dev" for 51); rc 1 and no
# output when no var maps the id. Names expand sorted, so a duplicate id
# resolves to the alphabetically-first var — deterministic, and duplicates are
# a board-env bug, not a shape to support.
stage_name() {
    local var val
    for var in "${!KB_STAGE_@}"; do
        val="${!var}"
        [[ -n "$val" && "$val" == "$1" ]] || continue
        printf '%s' "${var#KB_STAGE_}" | tr '[:upper:]' '[:lower:]'
        return 0
    done
    return 1
}
# Resolve a --type alias to the board's NATIVE card_type_id, config-driven from
# KB_TYPE_<ALIAS> in the board env — ANY alias, not a hardcoded six (so a board's
# own taxonomy, e.g. KB_TYPE_TECH_DEBT, types all its cards). Prints the id ONLY
# when the board has a real native type for the alias; prints nothing when the
# caller should fall back to a `type:<alias>` tag — i.e. the alias is unset/`000`,
# or KB_TYPING_MODE=tags forces tag mode. NEVER fails: a board with no native types
# (all-tag) or only some (mixed) is a supported shape, not an error. This
# generalizes the BR-3.3 field-skip (version_target) from custom fields to types.
native_type_id() {
    [[ "${KB_TYPING_MODE:-}" == "tags" ]] && return 0   # forced tag mode → no native id
    local var id
    var="KB_TYPE_$(printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_')"
    id="${!var:-}"
    # A real native id is a positive integer; "", "0", "000", non-numeric ⇒ tag fallback.
    [[ "$id" =~ ^[0-9]+$ && "$id" -gt 0 ]] && printf '%s' "$id"
    return 0
}

# DL canonicalization (the strict `--dl` → DL-NNN write-site fix, #3400 / canon #5)
# lives in kb_dl_canon in the shared lib; call it directly below.

# Resolve a "task ref" to a numeric task id.
#   Numeric → returned as-is.
#   Non-numeric → looked up by external_id on the board (search endpoint).
resolve_task() {
    local ref="$1"
    if [[ "$ref" =~ ^[0-9]+$ ]]; then
        [[ "$ref" -ge 1 ]] || { echo "kbcard: invalid task id '$ref'" >&2; exit 1; }
        echo "$ref"; return 0
    fi
    local id q
    # URL-encode the whole query value so a ref with & # space % can't corrupt
    # the query string or inject params (e.g. ref='x&board_id=999' retargeting).
    q="$(jq -rn --arg b "$KB_BOARD_ID" --arg r "$ref" '"board_id=\($b) external_id:\($r)" | @uri')"
    id="$(kb_api GET "/tasks/search.json?q=$q" | jq -r '.data[0].id // empty')"
    if [[ -z "$id" || "$id" == "null" ]]; then
        echo "kbcard: no task found with external_id='$ref' on board $KB_BOARD_ID" >&2; return 1
    fi
    [[ "$id" =~ ^[0-9]+$ && "$id" -ge 1 ]] || { echo "kbcard: invalid task id '$id'" >&2; exit 1; }
    echo "$id"
}

cmd_create_card() {
    local type="" name="" column="backlog" desc="" tags="" ext_id="" dl="" pr="" pr_url="" version="" origin="" triaged=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type) type="$2"; shift 2 ;;
            --name) name="$2"; shift 2 ;;
            --column) column="$2"; shift 2 ;;
            --description) desc="$2"; shift 2 ;;
            --tags) tags="$2"; shift 2 ;;
            --external-id) ext_id="$2"; shift 2 ;;
            --dl) dl="$2"; shift 2 ;;
            --pr) pr="$2"; shift 2 ;;
            --pr-url) pr_url="$2"; shift 2 ;;
            --version) version="$2"; shift 2 ;;
            --origin) origin="$2"; shift 2 ;;
            --triaged) triaged=1; shift ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$name" ]] && { echo "kbcard: --name required" >&2; return 2; }
    [[ -z "$type" ]] && { echo "kbcard: --type required" >&2; return 2; }
    # The alias maps to KB_TYPE_<NAME> and (on a non-native board) a `type:<name>`
    # tag, so it must be tag-safe — reject commas/spaces that would corrupt the CSV.
    [[ "$type" =~ ^[A-Za-z0-9_-]+$ ]] || { echo "kbcard: --type '$type' must be alphanumeric / '-' / '_'" >&2; return 2; }

    local stage type_id payload_args=()
    stage="$(stage_id "$column")"
    type_id="$(native_type_id "$type")"
    # Tag fallback (generalizes BR-3.3): a board with no native type for this alias
    # (all-tag, mixed, or KB_TYPING_MODE=tags) gets a `type:<alias>` tag instead of a
    # bad card_type_id:0. The native path (real id) is unchanged.
    [[ -z "$type_id" ]] && tags="${tags:+$tags,}type:${type}"
    # --triaged: born-triaged, symmetric with `patch --triaged`. On a fresh card the
    # CSV is built here, so a plain append suffices (no read-merge-write like patch).
    [[ -n "$triaged" ]] && tags="${tags:+$tags,}triaged"

    if [[ -n "$dl" ]]; then dl="$(kb_dl_canon "$dl")" || return 2; payload_args+=("dl_number=$dl"); fi
    [[ -n "$pr" ]]      && payload_args+=("pr_number=$pr")
    [[ -n "$pr_url" ]]  && payload_args+=("pr_url=$pr_url")   # sets the by-ref `source` (owner/repo); pr_number does not
    # BR-3.3: only write version_target if the board actually has that custom field
    # (its id declared as KB_CF_VERSION_TARGET in the board env) — else the write
    # 422s (kanban gates payload keys to registered fields). Warn, don't drop
    # silently, so a misconfigured board surfaces instead of vanishing the value.
    if [[ -n "$version" ]]; then
        if [[ -n "${KB_CF_VERSION_TARGET:-}" && "${KB_CF_VERSION_TARGET}" != "000" ]]; then
            payload_args+=("version_target=$version")
        else
            echo "kbcard: --version ignored — this board has no version_target field (declare KB_CF_VERSION_TARGET in its board env to enable)" >&2
        fi
    fi
    [[ -n "$origin" ]]  && payload_args+=("origin=$origin")

    # Build payload as a JSON object. Coerce numeric strings to JSON numbers so
    # number-typed custom fields (e.g. pr_number) don't 422 with "Must be a number".
    local payload_json="{}"
    if [[ ${#payload_args[@]} -gt 0 ]]; then
        payload_json="$(printf '%s\n' "${payload_args[@]}" | jq -R 'capture("^(?<k>[^=]+)=(?<v>.*)$") | {(.k): (.v | tonumber? // .)}' | jq -s 'add')"
    fi

    # external_id is the integer per-board sync id (tasks.external_id is an
    # unsignedBigInteger). Reject a non-numeric value LOUDLY instead of silently
    # coercing it to null and discarding the caller's input (fail-loud stance).
    if [[ -n "$ext_id" && ! "$ext_id" =~ ^[0-9]+$ ]]; then
        echo "kbcard: --external-id must be numeric (the integer per-board sync id); got '$ext_id'. For a DL id use --dl." >&2
        return 2
    fi

    # Build inner task object; POST body wraps it in {task: ...} per V3 API contract.
    local body
    body="$(jq -n \
        --arg name "$name" \
        --argjson board "$KB_BOARD_ID" \
        --argjson stage "$stage" \
        --arg type_id "$type_id" \
        --arg desc "$desc" \
        --arg tags "$tags" \
        --arg ext_id "$ext_id" \
        --argjson payload "$payload_json" \
        '{name: $name, board_id: $board, workflow_stage_id: $stage}
         + (if $type_id != "" then {card_type_id: ($type_id | tonumber)} else {} end)
         + (if $desc  != "" then {description: $desc} else {} end)
         + (if $tags  != "" then {tags: ($tags | split(","))} else {} end)
         + (if $ext_id != "" then {external_id: ($ext_id | tonumber)} else {} end)
         + (if ($payload | length) > 0 then {payload: $payload} else {} end)
         | {task: .}')"

    kb_api POST "/tasks.json" "$body" | _kbc_write_echo
}

cmd_move() {
    local task_ref="" column=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            --column) column="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$task_ref" || -z "$column" ]] && { echo "kbcard: --task and --column required" >&2; return 2; }
    local task stage body
    task="$(resolve_task "$task_ref")"
    stage="$(stage_id "$column")"
    body="$(jq -n --argjson stage "$stage" '{task: {workflow_stage_id: $stage}}')"
    kb_api PATCH "/tasks/$task.json" "$body" | jq '.data | {id, name, workflow_stage_id}'
}

cmd_patch() {
    local task_ref="" pr="" pr_url="" version="" column="" desc="" dl="" triaged=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            --pr) pr="$2"; shift 2 ;;
            --pr-url) pr_url="$2"; shift 2 ;;
            --version) version="$2"; shift 2 ;;
            --column) column="$2"; shift 2 ;;
            --description) desc="$2"; shift 2 ;;
            --dl) dl="$2"; shift 2 ;;
            --triaged) triaged=1; shift ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$task_ref" ]] && { echo "kbcard: --task required" >&2; return 2; }
    local task; task="$(resolve_task "$task_ref")"

    local payload_args=()
    [[ -n "$pr" ]]      && payload_args+=("pr_number=$pr")
    # pr_url sets payload.pr_url, from which the kanban derives a card's by-ref `source`
    # (owner/repo, lowercased) — required for the repo-qualified PR→card lookup on a
    # multi-repo board; pr_number alone does NOT set source. Pre-PR placeholder form is
    # .../pull/0 (the repo segment is what matters; the poll reconciler overwrites the URL).
    [[ -n "$pr_url" ]]  && payload_args+=("pr_url=$pr_url")
    # BR-3.3: only write version_target if the board actually has that custom field
    # (its id declared as KB_CF_VERSION_TARGET in the board env) — else the write
    # 422s (kanban gates payload keys to registered fields). Warn, don't drop
    # silently, so a misconfigured board surfaces instead of vanishing the value.
    if [[ -n "$version" ]]; then
        if [[ -n "${KB_CF_VERSION_TARGET:-}" && "${KB_CF_VERSION_TARGET}" != "000" ]]; then
            payload_args+=("version_target=$version")
        else
            echo "kbcard: --version ignored — this board has no version_target field (declare KB_CF_VERSION_TARGET in its board env to enable)" >&2
        fi
    fi
    if [[ -n "$dl" ]]; then dl="$(kb_dl_canon "$dl")" || return 2; payload_args+=("dl_number=$dl"); fi

    local body inner='{}'
    if [[ ${#payload_args[@]} -gt 0 ]]; then
        local new_payload
        # Coerce numeric strings (pr_number is a number-typed custom field).
        new_payload="$(printf '%s\n' "${payload_args[@]}" | jq -R 'capture("^(?<k>[^=]+)=(?<v>.*)$") | {(.k): (.v | tonumber? // .)}' | jq -s 'add')"
        # Send only the keys we're changing: the kanban v3 API MERGES task.payload
        # per-key (kanban #2180) — a key we omit is left as-is, an explicit null
        # clears it. So a bare {dl_number} no longer wipes the other custom fields,
        # and no read-merge-write is needed. Sending only the delta also preserves a
        # concurrent edit to any OTHER field: a full read-merge-write would clobber
        # it with our stale pre-PATCH read (the lost-update guarantee #2180 adds).
        inner="$(jq -n --argjson p "$new_payload" '{payload: $p}')"
    fi
    if [[ -n "$column" ]]; then
        local stage; stage="$(stage_id "$column")"
        inner="$(jq -n --argjson cur "$inner" --argjson stage "$stage" '$cur + {workflow_stage_id: $stage}')"
    fi
    if [[ -n "$desc" ]]; then
        inner="$(jq -n --argjson cur "$inner" --arg d "$desc" '$cur + {description: $d}')"
    fi
    if [[ -n "$triaged" ]]; then
        # tags are a top-level string list, replaced WHOLESALE by the API — so
        # read-merge-write to add `triaged` without dropping existing tags.
        local cur_tags new_tags
        cur_tags="$(kb_api GET "/tasks/$task.json" | jq '.data.tags // []')"
        new_tags="$(jq -n --argjson cur "$cur_tags" '($cur + ["triaged"]) | unique')"
        inner="$(jq -n --argjson cur "$inner" --argjson tags "$new_tags" '$cur + {tags: $tags}')"
    fi
    body="$(jq -n --argjson t "$inner" '{task: $t}')"
    kb_api PATCH "/tasks/$task.json" "$body" | _kbc_write_echo 'description: (.description // "" | .[0:80])'
}

cmd_list() {
    local column="" type=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --column) column="$2"; shift 2 ;;
            --type) type="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    # TaskSearch DSL doesn't expose workflow_stage_id / card_type_id directly —
    # by design, not a bug. workflow_stage_id was explicitly declined per sola-pm
    # 2026-05-19 (client-side filtering deemed sufficient); card_type: is on the
    # DL-013 long-tail list as a candidate-if-asked. Filter client-side via jq.
    local stage_filter type_filter
    if [[ -n "$column" ]]; then stage_filter="$(stage_id "$column")"; fi
    if [[ -n "$type" ]];   then type_filter="$(native_type_id "$type")"; fi

    # Whole-board fetch (paginated, accumulate-via-STDIN, dedup) is the shared
    # fetch_board_cards primitive — reading only page 1 silently UNDERCOUNTS every
    # column once a board exceeds one page. Any fetch failure (unreachable /
    # incomplete / over BOARD_PAGE_CAP) → exit 1 rather than print a truncated list.
    local cards
    cards="$(fetch_board_cards "$KB_API" "$KB_TOKEN" "$KB_BOARD_ID" "${BOARD_PAGE_CAP:-50}")" \
        || { echo "kbcard: failed to read board $KB_BOARD_ID" >&2; exit 1; }
    # --type resolves per alias by board capability: when the board has a NATIVE id
    # for the alias ($type != null) match card_type_id; otherwise ($type == null —
    # all-tag/mixed/KB_TYPING_MODE) match the `type:<alias>` tag. The two clauses are
    # MUTUALLY EXCLUSIVE — gating the tag clause on `$type == null` avoids both (a) an
    # all-tag board matching every null-typed card, and (b) a native board surfacing a
    # differently-typed card that carries a stray type:<alias> tag.
    printf '%s' "$cards" | jq \
        --argjson stage "${stage_filter:-null}" \
        --argjson type "${type_filter:-null}" \
        --arg typetag "${type:+type:$type}" \
        '(. // [])
         | map(select(($stage == null or .workflow_stage_id == $stage)
                and ($typetag == ""
                     or ($type != null and .card_type_id == $type)
                     or ($type == null and ((.tags // []) | index($typetag)) != null))))
         | map(.payload = (if (.payload | type) == "object" then .payload else {} end))
         | map({id, name, stage: .workflow_stage_id, type: .card_type_id, dl: .payload.dl_number, pr: .payload.pr_number})'
}

cmd_link() {
    local from="" to="" relation=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from) from="$2"; shift 2 ;;
            --to) to="$2"; shift 2 ;;
            --relation) relation="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$from" || -z "$to" || -z "$relation" ]] && { echo "kbcard: --from --to --relation required" >&2; return 2; }
    local f t body
    f="$(resolve_task "$from")"
    t="$(resolve_task "$to")"
    body="$(jq -n --argjson from "$f" --argjson to "$t" --arg rel "$relation" '{from_task_id: $from, to_task_id: $to, relation_type: $rel}')"
    kb_api POST "/task_links.json" "$body" | jq '.data'
}

# _kbc_annotate_card <task-json>: the task with `stage` populated from
# workflow_stage_id (parity with cmd_list's stage field) and `column` set to the
# board's column name for that stage (stage_name reverse lookup). A field this
# tool cannot populate is OMITTED, never null — an emitted `"stage": null` on a
# card that IS in a stage reads as "no stage" and caused a false "auto-move is
# broken" escalation (card #4387). Deleting also scrubs a serializer-provided
# _kbc_write_echo: the create/patch echo projection — payload rides ONLY when the
# serializer sent the key (fabricating `payload: null` asserts "no payload" where
# the truth is "key absent", #4390); a server-sent null passes through unaltered.
# $1 = extra jq object fields (e.g. description truncation), defaults to none.
_kbc_write_echo() {
    jq ".data | {id, name, workflow_stage_id${1:+, $1}} + (if has(\"payload\") then {payload} else {} end)"
}

# null stage/column, so the rule holds regardless of the API's response shape.
_kbc_annotate_card() {
    local data="$1" sid col=""
    sid="$(printf '%s' "$data" | jq -r '.workflow_stage_id // empty')"
    if [[ -n "$sid" ]]; then
        col="$(stage_name "$sid" || true)"
    fi
    printf '%s' "$data" | jq --arg col "$col" '
        (if .workflow_stage_id != null then .stage = .workflow_stage_id else del(.stage) end)
        | (if $col != "" then .column = $col else del(.column) end)'
}

cmd_show() {
    local task_ref=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    local task data
    task="$(resolve_task "$task_ref")"
    data="$(kb_api GET "/tasks/$task.json" | jq '.data')"
    _kbc_annotate_card "$data"
}

# Take a card off the board without deleting it: PATCH _action:archive. The row
# stays live (recoverable via _action:unarchive) and keeps its stable id + any
# dl_number — so archiving never releases a DL ref. `--dry-run` prints the call.
cmd_archive() {
    local task_ref="" dry=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            --dry-run) dry=1; shift ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$task_ref" ]] && { echo "kbcard: --task required" >&2; return 2; }
    local task; task="$(resolve_task "$task_ref")" || return 2
    if [[ -n "$dry" ]]; then
        echo "  archive:  PATCH /tasks/$task.json  {\"_action\":\"archive\"}"
        return 0
    fi
    kb_api PATCH "/tasks/$task.json" '{"_action":"archive"}' >/dev/null \
        || { echo "kbcard: archive failed for task $task" >&2; return 1; }
    echo "kbcard: task $task archived (off-board, recoverable; live row — stable id + DL ref kept)"
}

# Remove a card. Default is a soft delete (PATCH _action:delete) — trashed, but
# recoverable within the retention window, and it RETAINS the dl_number. `--hard`
# force-deletes (POST force-delete.json): permanent, cascades subtasks/comments/
# links, and RELEASES the DL ref. force-delete 422s unless the card is already
# trashed, so --hard is a two-step soft-then-force; the confirmation gates the
# whole thing, BEFORE the soft-delete, so a declined --hard leaves the card live.
cmd_delete() {
    local task_ref="" hard="" dry="" yes="" ans=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            --hard) hard=1; shift ;;
            --dry-run) dry=1; shift ;;
            --yes|-y) yes=1; shift ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$task_ref" ]] && { echo "kbcard: --task required" >&2; return 2; }
    local task; task="$(resolve_task "$task_ref")" || return 2

    if [[ -n "$dry" ]]; then
        echo "  soft:  PATCH /tasks/$task.json  {\"_action\":\"delete\"}"
        [[ -n "$hard" ]] && echo "  hard:  POST  /tasks/$task/force-delete.json  (IRREVERSIBLE — releases DL ref)"
        return 0
    fi

    # Confirm the destructive path FIRST — before any deletion — so declining (or
    # a non-interactive shell without --yes) leaves the card fully live, never in a
    # half-trashed state. A non-TTY with no --yes refuses rather than reading a
    # confirmation from a stream that carries none (fail-closed on irreversibility).
    if [[ -n "$hard" && -z "$yes" ]]; then
        if [[ ! -t 0 ]]; then
            echo "kbcard: --hard requires --yes in a non-interactive shell (refusing to permanently delete without an explicit confirmation)" >&2
            return 2
        fi
        # `|| ans=""` so an EOF (Ctrl-D) at the prompt takes the graceful abort
        # path (read returns non-zero on EOF, which set -e would otherwise fatal).
        read -r -p "HARD-delete task $task PERMANENTLY (cascades subtasks/comments/links; releases DL ref; irreversible)? [y/N] " ans || ans=""
        [[ "$ans" == [yY] ]] || { echo "kbcard: aborted — task $task left live (not deleted)"; return 0; }
    fi

    kb_api PATCH "/tasks/$task.json" '{"_action":"delete"}' >/dev/null \
        || { echo "kbcard: soft-delete failed for task $task" >&2; return 1; }
    if [[ -z "$hard" ]]; then
        echo "kbcard: task $task soft-deleted (recoverable within the retention window; DL ref RETAINED — use --hard to release it)"
        return 0
    fi
    kb_api POST "/tasks/$task/force-delete.json" '' >/dev/null \
        || { echo "kbcard: force-delete failed for task $task (needs task.delete / admin). The card is now SOFT-DELETED (in the trash, recoverable) — retry --hard with an admin token, or restore it." >&2; return 1; }
    echo "kbcard: task $task HARD-deleted (permanent; DL ref released)"
}

main() {
    # Optional global `--board NAME` before the subcommand selects the board env.
    local board_name=""
    if [[ "${1:-}" == "--board" ]]; then
        board_name="${2:-}"
        shift 2
    fi
    # Resolves board env + host env + token; sets KB_API / KB_BOARD_ID / KB_TOKEN.
    kb_load_config "$board_name" || exit 2

    local cmd="${1:-}"
    [[ -z "$cmd" ]] && { sed -n '/^# Usage:/,/^$/p' "$0" | sed 's/^# //'; exit 0; }
    shift
    case "$cmd" in
        create-card) cmd_create_card "$@" ;;
        move)        cmd_move "$@" ;;
        patch)       cmd_patch "$@" ;;
        list)        cmd_list "$@" ;;
        link)        cmd_link "$@" ;;
        show)        cmd_show "$@" ;;
        archive)     cmd_archive "$@" ;;
        delete)      cmd_delete "$@" ;;
        *) echo "kbcard: unknown command '$cmd'" >&2; exit 2 ;;
    esac
}

# run main only when executed directly, so tests/kbcard-selftest.sh can source the pure fns.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then main "$@"; fi
