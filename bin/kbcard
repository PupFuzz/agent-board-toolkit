#!/usr/bin/env bash
# kbcard — thin wrapper for the kanban-board production board API
# Lives outside the kanbanboard repo. Token path + board state live in
# ~/.kanban-dev-token and ~/.kanban-dev-board.env so the script is portable.
#
# Usage:
#   kbcard create-card --type <alias> --name "title" \
#                      --column backlog|prioritized|in_progress|in_review|held|shipped_to_dev|released_to_main|wont_do \
#     <alias> is config-driven: any KB_TYPE_<ALIAS> in the board env writes that
#     native card_type_id; an unset/`000` alias (or KB_TYPING_MODE=tags) instead
#     omits card_type_id and tags the card `type:<alias>` — so create-card/list work
#     on native, all-tag, and mixed boards alike.
#                      [--description "..."] [--tags "tag1,tag2"] [--external-id 12345] \
#                      [--dl "DL-093"] [--pr 178] [--pr-url URL] [--issue 42] [--issue-url URL] [--version "v0.9.2"] [--origin preemptive|consumer-driven|incident-triggered|user-requested] [--triaged]
#     --triaged tags the card `triaged` at birth (symmetric with `patch --triaged`)
#     so a plain PM-minted card isn't a false-positive untriaged next session.
#   kbcard move --task ID-OR-EXT --column COLUMN
#   kbcard patch --task ID-OR-EXT [--pr N] [--pr-url URL] [--issue N] [--issue-url URL] [--version VER] [--column COL] [--swimlane NAME-OR-ID] [--description "..."] [--dl DL-NNN] [--triaged]
#     --swimlane writes the card's top-level swimlane_id, resolving a name via the same
#     board-env map `list --swimlane` uses (numeric id passes through). --swimlane none
#     (or 0) un-assigns the card from its swimlane (writes swimlane_id null).
#     --pr-url writes payload.pr_url — the kanban derives a card's by-ref `source` (owner/repo)
#     from it; required for the repo-qualified PR→card lookup on a multi-repo board (--pr alone
#     sets pr_number, not source). Pre-PR placeholder: https://github.com/<owner>/<repo>/pull/0
#     --issue / --issue-url are the issue-lifecycle mirror of --pr / --pr-url: they write
#     payload.issue_number (numeric-canonicalized) + payload.issue_url, and --issue-url likewise
#     drives the by-ref `source` (owner/repo) for the issue→card lookup on a multi-repo board.
#     Independent of the pr_* pair — a card can carry both an issue ref and a PR ref at once.
#   kbcard list  [--column COL] [--type TYPE] [--swimlane NAME-OR-ID]
#   kbcard link --from TASK --to TASK --relation "bundles"|"blocks"|"caused"
#   kbcard show --task ID-OR-EXT
#   kbcard archive --task ID-OR-EXT [--force] [--dry-run]
#     Take the card off the board without deleting it (PATCH _action:archive) —
#     the row stays live + recoverable and keeps its stable id + dl_number.
#     Refuses (rc 1, no PATCH) if the card's backing coordination source (its
#     pr_number/issue_number by-ref, or id:<sid> tag) is still LIVE and has no
#     surviving twin card — archiving its only card would hide a live source from
#     the reconcile/detect backstop (roundtable #39). --force overrides the gate
#     and records an audited override line (stderr + the kbcard failure log).
#   kbcard delete --task ID-OR-EXT [--hard] [--yes|-y] [--dry-run]
#     Default: soft-delete (trashed, recoverable within the retention window; RETAINS
#     dl_number). --hard: permanent force-delete (cascades subtasks/comments/links;
#     RELEASES dl_number; two-step soft-then-force). --hard prompts to confirm unless
#     --yes, and refuses without --yes in a non-interactive shell. --dry-run prints
#     the exact API calls without executing them.
#
# Source of truth for IDs:
#   ~/.kanban-dev-board.env — sourced for stage/type/cf ID lookups.

set -euo pipefail

# Shared toolkit lib (config resolution, API wrapper, pagination, DL canon).
KB_LIB="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/_kb-board-lib.sh"
[ -r "$KB_LIB" ] || { echo "$(basename "${BASH_SOURCE[0]}"): shared lib _kb-board-lib.sh not found next to this script — reinstall per INSTALL.md §3 (symlink all of bin/), or vendor _kb-board-lib.sh alongside this tool." >&2; exit 1; }
# shellcheck source=bin/_kb-board-lib.sh
source "$KB_LIB"

# kb_api knobs: own message prefix, the failure log, and echo the error body.
KB_PROG="kbcard"
KB_LOG_FILE="${KBCARD_LOG_FILE:-$HOME/.kbcard-failures.log}"
KB_API_ERRBODY=1
# fetch_board_cards (cmd_list) must report + log a page-fetch failure loudly like
# every other kbcard subcommand — not exit silently. KB_LOG_FILE above is the sink.
KB_FETCH_LOUD=1

# Config (board env + host env + token) is resolved in main() once the optional
# `--board NAME` global flag is parsed, via kb_load_config. Card types are
# per-board: `native_type_id` resolves a `--type` alias to KB_TYPE_<ALIAS> from
# the board env (any alias), writing the native id when present and falling back
# to a `type:<alias>` tag when the board lacks that native type — so an alias
# absent on one board (`fr` on kanban, `request`/`idea` on bridge) is tagged, not
# rejected. (`stage_id` still rejects an unknown column — stages are required.)
# API base is board-independent and NOT baked in — kb_load_config reads it from
# ~/.kanban-host.env (override via $KANBAN_HOST_ENV); see docs/INSTALL.md.

stage_id() {
    local id
    case "$1" in
        backlog) id="${KB_STAGE_BACKLOG:-}" ;;
        prioritized) id="${KB_STAGE_PRIORITIZED:-}" ;;
        in_progress) id="${KB_STAGE_IN_PROGRESS:-}" ;;
        in_review) id="${KB_STAGE_IN_REVIEW:-}" ;;
        held) id="${KB_STAGE_HELD:-}" ;;
        shipped_to_dev) id="${KB_STAGE_SHIPPED_TO_DEV:-}" ;;
        released_to_main) id="${KB_STAGE_RELEASED_TO_MAIN:-}" ;;
        wont_do) id="${KB_STAGE_WONT_DO:-}" ;;
        *) echo "kbcard: unknown column '$1'" >&2; return 2 ;;
    esac
    [[ -z "$id" ]] && { echo "kbcard: column '$1' is not defined on this board" >&2; return 2; }
    echo "$id"
}
# Reverse of stage_id: the column NAME for a native stage id, from whatever
# KB_STAGE_* vars the sourced board env defines (any of them, not just the eight
# stage_id aliases — a board's own taxonomy resolves too). Prints the lowercased
# suffix (KB_STAGE_SHIPPED_TO_DEV=51 → "shipped_to_dev" for 51); rc 1 and no
# output when no var maps the id. Names expand sorted, so a duplicate id
# resolves to the alphabetically-first var — deterministic, and duplicates are
# a board-env bug, not a shape to support.
stage_name() {
    local var val
    for var in "${!KB_STAGE_@}"; do
        val="${!var}"
        [[ -n "$val" && "$val" == "$1" ]] || continue
        printf '%s' "${var#KB_STAGE_}" | tr '[:upper:]' '[:lower:]'
        return 0
    done
    return 1
}
# Resolve a --type alias to the board's NATIVE card_type_id, config-driven from
# KB_TYPE_<ALIAS> in the board env — ANY alias, not a hardcoded six (so a board's
# own taxonomy, e.g. KB_TYPE_TECH_DEBT, types all its cards). Prints the id ONLY
# when the board has a real native type for the alias; prints nothing when the
# caller should fall back to a `type:<alias>` tag — i.e. the alias is unset/`000`,
# or KB_TYPING_MODE=tags forces tag mode. NEVER fails: a board with no native types
# (all-tag) or only some (mixed) is a supported shape, not an error. This
# generalizes the BR-3.3 field-skip (version_target) from custom fields to types.
native_type_id() {
    [[ "${KB_TYPING_MODE:-}" == "tags" ]] && return 0   # forced tag mode → no native id
    local var id
    var="KB_TYPE_$(printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_')"
    id="${!var:-}"
    # A real native id is a positive integer; "", "0", "000", non-numeric ⇒ tag fallback.
    [[ "$id" =~ ^[0-9]+$ && "$id" -gt 0 ]] && printf '%s' "$id"
    return 0
}

# Swimlane id→name map for the `list` projection, as a JSON object built from the
# board env. Swimlanes are keyed by id (KB_SWIMLANE_<id>=<name>) — the INVERSE of
# KB_STAGE_<name>=<id> / KB_TYPE_<alias>=<id> — because swimlane names are freeform
# agent labels (hyphens, spaces) that can't be env-var suffixes, whereas stage/type
# names are a controlled vocabulary that can. Keys are strings (JSON object keys);
# empty-valued vars are skipped; `{}` when the board defines no swimlanes (then the
# projection resolves every name to null — truthful, not a fabrication).
_kbc_swimlane_map() {
    local var obj='{}'
    for var in "${!KB_SWIMLANE_@}"; do
        [[ -n "${!var}" ]] || continue
        obj="$(jq -c --arg k "${var#KB_SWIMLANE_}" --arg v "${!var}" '. + {($k): $v}' <<<"$obj")"
    done
    printf '%s' "$obj"
}
# Resolve a `--swimlane <name|id>` ref to a numeric swimlane id for the client-side
# filter. A numeric arg passes through unvalidated (the caller named a concrete id —
# an empty result is then a truthful "no cards in that lane", like an empty --column).
# A name reverse-resolves through the env map and errors LOUD (rc 2) when unmapped,
# so a typo never silently lists nothing — parity with stage_id's unknown-column contract.
swimlane_id() {
    local arg="$1" var
    [[ "$arg" =~ ^[0-9]+$ ]] && { printf '%s' "$arg"; return 0; }
    for var in "${!KB_SWIMLANE_@}"; do
        [[ -n "${!var}" && "${!var}" == "$arg" ]] || continue
        printf '%s' "${var#KB_SWIMLANE_}"; return 0
    done
    # Enumerate the board's defined swimlanes (id→name) so a "not defined" error
    # can't be misread as "the board has no such swimlane" — mirrors the board-not-
    # found error's "boards found on this box: …". The empty case (a board with no
    # KB_SWIMLANE_* declared) gets a distinct, honest line rather than an empty list.
    echo "kbcard: swimlane '$arg' is not defined on this board" >&2
    local lanes
    lanes="$(_kbc_swimlane_map | jq -r 'to_entries | sort_by(.key | tonumber) | map("\(.key)=\(.value)") | join(", ")')"
    if [[ -n "$lanes" ]]; then
        echo "kbcard:   defined swimlanes: $lanes" >&2
    else
        echo "kbcard:   this board defines no swimlanes (declare KB_SWIMLANE_<id>=<name> in its board env)" >&2
    fi
    return 2
}

# DL canonicalization (the strict `--dl` → DL-NNN write-site fix, #3400 / canon #5)
# lives in kb_dl_canon in the shared lib; call it directly below.

# Resolve a "task ref" to a numeric task id.
#   Numeric → returned as-is.
#   Non-numeric → looked up by external_id on the board (search endpoint).
resolve_task() {
    local ref="$1"
    if [[ "$ref" =~ ^[0-9]+$ ]]; then
        [[ "$ref" -ge 1 ]] || { echo "kbcard: invalid task id '$ref'" >&2; exit 1; }
        echo "$ref"; return 0
    fi
    local id q
    # URL-encode the whole query value so a ref with & # space % can't corrupt
    # the query string or inject params (e.g. ref='x&board_id=999' retargeting).
    q="$(jq -rn --arg b "$KB_BOARD_ID" --arg r "$ref" '"board_id=\($b) external_id:\($r)" | @uri')"
    id="$(kb_api GET "/tasks/search.json?q=$q" | jq -r '.data[0].id // empty')"
    if [[ -z "$id" || "$id" == "null" ]]; then
        echo "kbcard: no task found with external_id='$ref' on board $KB_BOARD_ID" >&2; return 1
    fi
    [[ "$id" =~ ^[0-9]+$ && "$id" -ge 1 ]] || { echo "kbcard: invalid task id '$id'" >&2; exit 1; }
    echo "$id"
}

# _kbc_build_payload <dl> <pr> <pr_url> <version> <issue> <issue_url> [origin]: assemble
# the task.payload object shared by create-card and patch from the optional card-metadata
# flags. Prints a JSON object (`{}` when nothing is set) on stdout; returns 2 on a malformed
# --dl (propagated from kb_dl_canon, before any output). Numeric-looking values are
# coerced to JSON numbers so number-typed custom fields (e.g. pr_number, issue_number)
# don't 422 with "Must be a number". issue_number/issue_url mirror pr_number/pr_url
# exactly: issue_url sets the by-ref `source` (owner/repo) for multi-repo boards, issue_number
# alone does not — and the two lifecycle keys are INDEPENDENT of the pr_* pair, so a card can
# carry both. The positional contract: dl/pr/pr_url/version/issue/issue_url are common to both
# callers, so patch passes exactly that prefix; origin is create-card-only and trails so patch
# needn't pass an empty placeholder for it. Everything rides the SAME coercion path — a value
# must flow through this single merge rather than be appended by the caller, which would
# re-duplicate the merge jq this helper exists to unify.
_kbc_build_payload() {
    local dl="$1" pr="$2" pr_url="$3" version="$4" issue="${5:-}" issue_url="${6:-}" origin="${7:-}"
    local payload_args=()
    if [[ -n "$dl" ]]; then dl="$(kb_dl_canon "$dl")" || return 2; payload_args+=("dl_number=$dl"); fi
    [[ -n "$pr" ]]        && payload_args+=("pr_number=$pr")
    [[ -n "$pr_url" ]]    && payload_args+=("pr_url=$pr_url")       # sets the by-ref `source` (owner/repo); pr_number does not
    [[ -n "$issue" ]]     && payload_args+=("issue_number=$issue")
    [[ -n "$issue_url" ]] && payload_args+=("issue_url=$issue_url") # sets the by-ref `source` (owner/repo); issue_number does not
    # BR-3.3: only write version_target if the board actually has that custom field
    # (its id declared as KB_CF_VERSION_TARGET in the board env) — else the write
    # 422s (kanban gates payload keys to registered fields). Warn, don't drop
    # silently, so a misconfigured board surfaces instead of vanishing the value.
    if [[ -n "$version" ]]; then
        if [[ -n "${KB_CF_VERSION_TARGET:-}" && "${KB_CF_VERSION_TARGET}" != "000" ]]; then
            payload_args+=("version_target=$version")
        else
            echo "kbcard: --version ignored — this board has no version_target field (declare KB_CF_VERSION_TARGET in its board env to enable)" >&2
        fi
    fi
    [[ -n "$origin" ]]  && payload_args+=("origin=$origin")

    # Build payload as a JSON object. Coerce numeric strings to JSON numbers so
    # number-typed custom fields (e.g. pr_number) don't 422 with "Must be a number".
    local payload_json="{}"
    if [[ ${#payload_args[@]} -gt 0 ]]; then
        payload_json="$(printf '%s\n' "${payload_args[@]}" | jq -R 'capture("^(?<k>[^=]+)=(?<v>.*)$") | {(.k): (.v | tonumber? // .)}' | jq -s 'add')"
    fi
    printf '%s' "$payload_json"
}

cmd_create_card() {
    local type="" name="" column="backlog" desc="" tags="" ext_id="" dl="" pr="" pr_url="" issue="" issue_url="" version="" origin="" triaged=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type) type="$2"; shift 2 ;;
            --name) name="$2"; shift 2 ;;
            --column) column="$2"; shift 2 ;;
            --description) desc="$2"; shift 2 ;;
            --tags) tags="$2"; shift 2 ;;
            --external-id) ext_id="$2"; shift 2 ;;
            --dl) dl="$2"; shift 2 ;;
            --pr) pr="$2"; shift 2 ;;
            --pr-url) pr_url="$2"; shift 2 ;;
            --issue) issue="$2"; shift 2 ;;
            --issue-url) issue_url="$2"; shift 2 ;;
            --version) version="$2"; shift 2 ;;
            --origin) origin="$2"; shift 2 ;;
            --triaged) triaged=1; shift ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$name" ]] && { echo "kbcard: --name required" >&2; return 2; }
    [[ -z "$type" ]] && { echo "kbcard: --type required" >&2; return 2; }
    # The alias maps to KB_TYPE_<NAME> and (on a non-native board) a `type:<name>`
    # tag, so it must be tag-safe — reject commas/spaces that would corrupt the CSV.
    [[ "$type" =~ ^[A-Za-z0-9_-]+$ ]] || { echo "kbcard: --type '$type' must be alphanumeric / '-' / '_'" >&2; return 2; }

    local stage type_id
    stage="$(stage_id "$column")"
    type_id="$(native_type_id "$type")"
    # Tag fallback (generalizes BR-3.3): a board with no native type for this alias
    # (all-tag, mixed, or KB_TYPING_MODE=tags) gets a `type:<alias>` tag instead of a
    # bad card_type_id:0. The native path (real id) is unchanged.
    [[ -z "$type_id" ]] && tags="${tags:+$tags,}type:${type}"
    # --triaged: born-triaged, symmetric with `patch --triaged`. On a fresh card the
    # CSV is built here, so a plain append suffices (no read-merge-write like patch).
    [[ -n "$triaged" ]] && tags="${tags:+$tags,}triaged"

    # Assemble task.payload from the card-metadata flags (shared with cmd_patch).
    local payload_json
    payload_json="$(_kbc_build_payload "$dl" "$pr" "$pr_url" "$version" "$issue" "$issue_url" "$origin")" || return 2

    # external_id is the integer per-board sync id (tasks.external_id is an
    # unsignedBigInteger). Reject a non-numeric value LOUDLY instead of silently
    # coercing it to null and discarding the caller's input (fail-loud stance).
    if [[ -n "$ext_id" && ! "$ext_id" =~ ^[0-9]+$ ]]; then
        echo "kbcard: --external-id must be numeric (the integer per-board sync id); got '$ext_id'. For a DL id use --dl." >&2
        return 2
    fi

    # Build the task object; the v3 write API takes task fields FLAT at the top level
    # (kanban DL-219 dropped the {task: ...} body wrapper), so the object IS the POST body.
    local body
    body="$(jq -n \
        --arg name "$name" \
        --argjson board "$KB_BOARD_ID" \
        --argjson stage "$stage" \
        --arg type_id "$type_id" \
        --arg desc "$desc" \
        --arg tags "$tags" \
        --arg ext_id "$ext_id" \
        --argjson payload "$payload_json" \
        '{name: $name, board_id: $board, workflow_stage_id: $stage}
         + (if $type_id != "" then {card_type_id: ($type_id | tonumber)} else {} end)
         + (if $desc  != "" then {description: $desc} else {} end)
         + (if $tags  != "" then {tags: ($tags | split(","))} else {} end)
         + (if $ext_id != "" then {external_id: ($ext_id | tonumber)} else {} end)
         + (if ($payload | length) > 0 then {payload: $payload} else {} end)')"

    kb_api POST "/tasks.json" "$body" | _kbc_write_echo
}

cmd_move() {
    local task_ref="" column=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            --column) column="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$task_ref" || -z "$column" ]] && { echo "kbcard: --task and --column required" >&2; return 2; }
    local task stage body
    task="$(resolve_task "$task_ref")"
    stage="$(stage_id "$column")"
    body="$(jq -n --argjson stage "$stage" '{workflow_stage_id: $stage}')"
    kb_api PATCH "/tasks/$task.json" "$body" | jq '.data | {id, name, workflow_stage_id}'
}

cmd_patch() {
    local task_ref="" pr="" pr_url="" issue="" issue_url="" version="" column="" desc="" dl="" triaged="" swimlane=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            --pr) pr="$2"; shift 2 ;;
            --pr-url) pr_url="$2"; shift 2 ;;
            --issue) issue="$2"; shift 2 ;;
            --issue-url) issue_url="$2"; shift 2 ;;
            --version) version="$2"; shift 2 ;;
            --column) column="$2"; shift 2 ;;
            --swimlane) swimlane="$2"; shift 2 ;;
            --description) desc="$2"; shift 2 ;;
            --dl) dl="$2"; shift 2 ;;
            --triaged) triaged=1; shift ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$task_ref" ]] && { echo "kbcard: --task required" >&2; return 2; }
    local task; task="$(resolve_task "$task_ref")"

    # Assemble task.payload from the card-metadata flags (shared with cmd_create_card).
    # pr_url sets payload.pr_url, from which the kanban derives a card's by-ref `source`
    # (owner/repo, lowercased) — required for the repo-qualified PR→card lookup on a
    # multi-repo board; pr_number alone does NOT set source. Pre-PR placeholder form is
    # .../pull/0 (the repo segment is what matters; the poll reconciler overwrites the URL).
    local payload_json
    payload_json="$(_kbc_build_payload "$dl" "$pr" "$pr_url" "$version" "$issue" "$issue_url")" || return 2

    local body inner='{}'
    # Send only the keys we're changing: the kanban v3 API MERGES task.payload
    # per-key (kanban #2180) — a key we omit is left as-is, an explicit null
    # clears it. So a bare {dl_number} no longer wipes the other custom fields,
    # and no read-merge-write is needed. Sending only the delta also preserves a
    # concurrent edit to any OTHER field: a full read-merge-write would clobber
    # it with our stale pre-PATCH read (the lost-update guarantee #2180 adds).
    if [[ "$payload_json" != "{}" ]]; then
        inner="$(jq -n --argjson p "$payload_json" '{payload: $p}')"
    fi
    if [[ -n "$column" ]]; then
        local stage; stage="$(stage_id "$column")"
        inner="$(jq -n --argjson cur "$inner" --argjson stage "$stage" '$cur + {workflow_stage_id: $stage}')"
    fi
    if [[ -n "$swimlane" ]]; then
        # swimlane_id is a top-level column (not a payload key), so it rides the inner
        # task object like workflow_stage_id — not the payload merge. `none`/`0` are the
        # explicit un-assign forms (→ null); every other ref resolves through the SAME
        # swimlane_id() helper `list` uses (name→id, numeric passthrough, loud rc 2 on a
        # typo). 0 is special-cased BEFORE the resolver because it passes a numeric ref
        # through unvalidated — writing swimlane_id:0 instead of the intended null.
        local swim_id
        if [[ "$swimlane" == "none" || "$swimlane" == "0" ]]; then
            swim_id="null"
        else
            swim_id="$(swimlane_id "$swimlane")" || return 2
        fi
        inner="$(jq -n --argjson cur "$inner" --argjson s "$swim_id" '$cur + {swimlane_id: $s}')"
    fi
    if [[ -n "$desc" ]]; then
        inner="$(jq -n --argjson cur "$inner" --arg d "$desc" '$cur + {description: $d}')"
    fi
    if [[ -n "$triaged" ]]; then
        # tags are a top-level string list, replaced WHOLESALE by the API — so
        # read-merge-write to add `triaged` without dropping existing tags.
        local cur_tags new_tags
        cur_tags="$(kb_api GET "/tasks/$task.json" | jq '.data.tags // []')"
        new_tags="$(jq -n --argjson cur "$cur_tags" '($cur + ["triaged"]) | unique')"
        inner="$(jq -n --argjson cur "$inner" --argjson tags "$new_tags" '$cur + {tags: $tags}')"
    fi
    body="$inner"
    # Surface swimlane_id in the write echo only when it was set, so a --swimlane patch
    # confirms the resulting lane (null after an unassign) — parity with the echo always
    # showing workflow_stage_id; other patches keep their existing echo shape.
    local echo_extra='description: (.description // "" | .[0:80])'
    [[ -n "$swimlane" ]] && echo_extra="$echo_extra, swimlane_id: (.swimlane_id // null)"
    kb_api PATCH "/tasks/$task.json" "$body" | _kbc_write_echo "$echo_extra"
}

# _kbc_list_project <stage_filter> <type_filter> <typetag> <swimlane_filter>:
# the pure jq projection+filter for `list`, reading the whole-board card array on
# STDIN. Each filter arg is "" for absent. Extracted from cmd_list so it is unit-
# testable on synthetic cards (board 12 has no swimlanes to exercise live).
#   --type resolves per alias by board capability: a NATIVE id ($type != null)
#   matches card_type_id; otherwise ($type == null — all-tag/mixed/KB_TYPING_MODE)
#   the `type:<alias>` tag. The two clauses are MUTUALLY EXCLUSIVE — gating the tag
#   clause on $type == null avoids (a) an all-tag board matching every null-typed
#   card and (b) a native board surfacing a card carrying a stray type:<alias> tag.
#   swimlane_id / swimlane are surfaced on every row; the name resolves through the
#   env map (null when the card has no lane or the board doesn't map that id). The
#   swimlane FILTER keys on the STRINGIFIED id — unlike the numeric stage/type
#   filters, whose id types are verified by the working --column path — because no
#   board reachable here populates swimlanes, so the API's swimlane_id JSON type
#   (number vs string) is unverifiable; stringifying both sides matches either and
#   shares the exact key derivation the name-map lookup uses (a numeric == would
#   silently drop a string-typed id — the quiet-wrong class this whole change fights).
_kbc_list_project() {
    local stage_filter="$1" type_filter="$2" typetag="$3" swimlane_filter="$4"
    local swmap; swmap="$(_kbc_swimlane_map)"
    jq \
        --argjson stage "${stage_filter:-null}" \
        --argjson type "${type_filter:-null}" \
        --arg typetag "$typetag" \
        --argjson swim "${swimlane_filter:-null}" \
        --argjson swmap "$swmap" \
        '(. // [])
         | map(select(($stage == null or .workflow_stage_id == $stage)
                and ($typetag == ""
                     or ($type != null and .card_type_id == $type)
                     or ($type == null and ((.tags // []) | index($typetag)) != null))
                and ($swim == null or ((.swimlane_id // null) | tostring) == ($swim | tostring))))
         | map(.payload = (if (.payload | type) == "object" then .payload else {} end))
         | map({id, name, stage: .workflow_stage_id, type: .card_type_id,
                swimlane_id: (.swimlane_id // null),
                swimlane: ($swmap[((.swimlane_id // null) | tostring)] // null),
                dl: .payload.dl_number, pr: .payload.pr_number})'
}

cmd_list() {
    local column="" type="" swimlane=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --column) column="$2"; shift 2 ;;
            --type) type="$2"; shift 2 ;;
            --swimlane) swimlane="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    # TaskSearch DSL doesn't expose workflow_stage_id / card_type_id / swimlane_id
    # directly — by design, not a bug. workflow_stage_id was explicitly declined per
    # sola-pm 2026-05-19 (client-side filtering deemed sufficient); card_type: is on
    # the DL-013 long-tail list. All three filters are client-side jq selects. A bad
    # --column/--swimlane exits 2 loudly under set -e (the resolver returns 2).
    local stage_filter type_filter swimlane_filter
    if [[ -n "$column" ]];   then stage_filter="$(stage_id "$column")"; fi
    if [[ -n "$type" ]];     then type_filter="$(native_type_id "$type")"; fi
    if [[ -n "$swimlane" ]]; then swimlane_filter="$(swimlane_id "$swimlane")"; fi

    # Whole-board fetch (paginated, accumulate-via-STDIN, dedup) is the shared
    # fetch_board_cards primitive — reading only page 1 silently UNDERCOUNTS every
    # column once a board exceeds one page. Any fetch failure (unreachable /
    # incomplete / over BOARD_PAGE_CAP) → exit 1 rather than print a truncated list.
    local cards
    cards="$(fetch_board_cards "$KB_API" "$KB_TOKEN" "$KB_BOARD_ID" "${BOARD_PAGE_CAP:-50}")" \
        || { echo "kbcard: failed to read board $KB_BOARD_ID" >&2; exit 1; }
    printf '%s' "$cards" | _kbc_list_project \
        "${stage_filter:-}" "${type_filter:-}" "${type:+type:$type}" "${swimlane_filter:-}"
}

cmd_link() {
    local from="" to="" relation=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from) from="$2"; shift 2 ;;
            --to) to="$2"; shift 2 ;;
            --relation) relation="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$from" || -z "$to" || -z "$relation" ]] && { echo "kbcard: --from --to --relation required" >&2; return 2; }
    local f t body
    f="$(resolve_task "$from")"
    t="$(resolve_task "$to")"
    body="$(jq -n --argjson from "$f" --argjson to "$t" --arg rel "$relation" '{from_task_id: $from, to_task_id: $to, relation_type: $rel}')"
    kb_api POST "/task_links.json" "$body" | jq '.data'
}

# _kbc_annotate_card <task-json>: the task with `stage` populated from
# workflow_stage_id (parity with cmd_list's stage field) and `column` set to the
# board's column name for that stage (stage_name reverse lookup). A field this
# tool cannot populate is OMITTED, never null — an emitted `"stage": null` on a
# card that IS in a stage reads as "no stage" and caused a false "auto-move is
# broken" escalation (card #4387). Deleting also scrubs a serializer-provided
# _kbc_write_echo: the create/patch echo projection — payload rides ONLY when the
# serializer sent the key (fabricating `payload: null` asserts "no payload" where
# the truth is "key absent", #4390); a server-sent null passes through unaltered.
# $1 = extra jq object fields (e.g. description truncation), defaults to none.
_kbc_write_echo() {
    jq ".data | {id, name, workflow_stage_id${1:+, $1}} + (if has(\"payload\") then {payload} else {} end)"
}

# null stage/column, so the rule holds regardless of the API's response shape.
_kbc_annotate_card() {
    local data="$1" sid col=""
    sid="$(printf '%s' "$data" | jq -r '.workflow_stage_id // empty')"
    if [[ -n "$sid" ]]; then
        col="$(stage_name "$sid" || true)"
    fi
    printf '%s' "$data" | jq --arg col "$col" '
        (if .workflow_stage_id != null then .stage = .workflow_stage_id else del(.stage) end)
        | (if $col != "" then .column = $col else del(.column) end)'
}

cmd_show() {
    local task_ref=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    local task data
    task="$(resolve_task "$task_ref")"
    data="$(kb_api GET "/tasks/$task.json" | jq '.data')"
    _kbc_annotate_card "$data"
}

# _kbc_board_repo: the board's canonical GitHub repo (owner/name), read from the
# coord config's kanban.boards[] entry whose board_id matches this board — the same
# board→repo map the reconcile hook uses. Best-effort: prints "" when the config is
# absent or the board isn't declared (the shim then falls back to the card's own
# pr_url/issue_url source, and finally to fail-closed). No network.
_kbc_board_repo() {
    local cfg="${COORD_CONFIG:-$HOME/.config/coord/coordination.config.json}"
    [[ -r "$cfg" ]] || return 0
    jq -r --arg id "$KB_BOARD_ID" '
        ((.kanban.boards // [])[] | select((.board_id|tostring) == $id) | .repo) // empty
    ' "$cfg" 2>/dev/null | head -n1
}

# _kbc_archive_decision <task-id>: run the may_archive safety gate for a card and
# print "<token>\t<reason>" (token = ok|blocked|noprimitive) on stdout. Delegates
# the policy to the shipped framework primitive via the _kbc-may-archive.py shim;
# builds no archive policy here. A missing shim, an unfetchable card, or any shim
# fault resolves to a fail-closed token so cmd_archive refuses rather than archiving
# unchecked. surviving_cards is the whole live board (twin detection is the
# primitive's job); a partial/failed board read yields fewer twins → more blocking
# (fail-closed), never a false allow.
_kbc_archive_decision() {
    local task="$1" shim card board repo
    shim="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/_kbc-may-archive.py"
    [[ -r "$shim" ]] || { printf 'noprimitive\tarchive-gate shim _kbc-may-archive.py not found next to kbcard'; return 0; }
    card="$(kb_api GET "/tasks/$task.json" | jq -c '.data')" \
        || { printf 'noprimitive\tcould not fetch card %s to verify archive safety' "$task"; return 0; }
    # A 2xx with .data null/absent (trashed / permission-limited / edge card) yields
    # the literal "null" (or "") at rc 0 — non-empty, so the `||` above never fires.
    # For the CARD input the degenerate default is UNSAFE (no card ⇒ no sources ⇒ a
    # false `ok` that archives a live-and-untwinned card), the mirror of the board
    # input's safe `[]` default above — so fail closed here, never reach the shim.
    [[ "$card" == "null" || -z "$card" ]] && { printf 'noprimitive\tcard %s fetch returned null .data — cannot verify archive safety' "$task"; return 0; }
    # Capture the board array regardless of the paginator's completeness rc — a
    # partial set only removes twins (more conservative), never invents one. The
    # `|| true` keeps a non-zero paginator rc (partial/short read) from aborting
    # this function under `set -e`.
    board="$(fetch_board_cards "$KB_API" "$KB_TOKEN" "$KB_BOARD_ID" 2>/dev/null)" || true
    [[ -n "$board" ]] || board="[]"
    repo="$(_kbc_board_repo)" || true
    # The board array can be ~200KB — it must reach jq via STDIN, never argv
    # (--argjson would trip "Argument list too long" over MAX_ARG_STRLEN, the
    # #3091/#3362 class; a silently-empty jq would then feed the shim {} and
    # mis-read the card as source-less → a FALSE ok). Only the single target card
    # (small) rides --argjson.
    printf '%s' "$board" | jq -c --argjson card "$card" \
           --arg repo "$repo" --arg board_id "$KB_BOARD_ID" \
        '{card:$card, surviving_cards:., repo:$repo, board_id:$board_id}' \
        | python3 "$shim"
}

# Take a card off the board without deleting it: PATCH _action:archive. The row
# stays live (recoverable via _action:unarchive) and keeps its stable id + any
# dl_number — so archiving never releases a DL ref. Before the PATCH the
# may_archive gate refuses to archive a card whose backing coordination source is
# still live-and-untwinned (archiving its only card would hide a live source from
# the reconcile/detect backstop); --force overrides with an audited log line.
# `--dry-run` prints the call without evaluating the gate (offline, no mutation).
cmd_archive() {
    local task_ref="" dry="" force=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            --dry-run) dry=1; shift ;;
            --force) force=1; shift ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$task_ref" ]] && { echo "kbcard: --task required" >&2; return 2; }
    local task; task="$(resolve_task "$task_ref")" || return 2
    if [[ -n "$dry" ]]; then
        echo "  archive:  PATCH /tasks/$task.json  {\"_action\":\"archive\"}"
        [[ -n "$force" ]] || echo "  note: the live-source archive gate is evaluated at execution (not in --dry-run)" >&2
        return 0
    fi

    # Archive-safety gate (roundtable #39). Skipped entirely under --force, which
    # then emits an audited override line rather than a silent bypass.
    if [[ -z "$force" ]]; then
        local decision token reason
        decision="$(_kbc_archive_decision "$task")"
        token="${decision%%$'\t'*}"; reason="${decision#*$'\t'}"
        case "$token" in
            ok) : ;;   # gate cleared — proceed to the PATCH below
            blocked)
                echo "kbcard: ⚠ archive withheld: card #$task — $reason" >&2
                echo "kbcard: pass --force to override (records an audited override); the card was NOT archived." >&2
                return 1 ;;
            *)  # noprimitive / any unrecognized token → fail LOUD, never silent-archive
                echo "kbcard: ⚠ archive withheld: card #$task — $reason" >&2
                echo "kbcard: cannot verify archive safety; pass --force to override (records an audited override). The card was NOT archived." >&2
                return 1 ;;
        esac
    else
        # Audit the override: what the gate WOULD have said, durably logged + on
        # stderr — a forced archive is never a silent bypass of the gate. Tolerate a
        # gate-infra failure (e.g. python3 absent → rc 127): --force is the escape
        # hatch, so it must not itself be blocked by the very gate infra it exists to
        # bypass. An empty decision still proceeds to the archive AND still writes the
        # audited override line (never a SILENT forced archive). The non-force branch
        # deliberately keeps no `|| …` here so a gate-infra failure there fails closed.
        local decision token reason
        decision="$(_kbc_archive_decision "$task")" || decision=""
        if [[ -z "$decision" ]]; then
            token=""; reason="archive-gate infra could not run — forced without a verified decision"
        else
            token="${decision%%$'\t'*}"; reason="${decision#*$'\t'}"
        fi
        if [[ "$token" != "ok" ]]; then
            local line="⚠ archive FORCED past live-source gate: card #$task — $reason"
            echo "kbcard: $line" >&2
            [[ -n "${KB_LOG_FILE:-}" ]] && echo "$(date -u +%FT%TZ) ARCHIVE-FORCE task=$task $line" >> "$KB_LOG_FILE"
        fi
    fi

    kb_api PATCH "/tasks/$task.json" '{"_action":"archive"}' >/dev/null \
        || { echo "kbcard: archive failed for task $task" >&2; return 1; }
    echo "kbcard: task $task archived (off-board, recoverable; live row — stable id + DL ref kept)"
}

# Remove a card. Default is a soft delete (PATCH _action:delete) — trashed, but
# recoverable within the retention window, and it RETAINS the dl_number. `--hard`
# force-deletes (POST force-delete.json): permanent, cascades subtasks/comments/
# links, and RELEASES the DL ref. force-delete 422s unless the card is already
# trashed, so --hard is a two-step soft-then-force; the confirmation gates the
# whole thing, BEFORE the soft-delete, so a declined --hard leaves the card live.
cmd_delete() {
    local task_ref="" hard="" dry="" yes="" ans=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            --hard) hard=1; shift ;;
            --dry-run) dry=1; shift ;;
            --yes|-y) yes=1; shift ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$task_ref" ]] && { echo "kbcard: --task required" >&2; return 2; }
    local task; task="$(resolve_task "$task_ref")" || return 2

    if [[ -n "$dry" ]]; then
        echo "  soft:  PATCH /tasks/$task.json  {\"_action\":\"delete\"}"
        [[ -n "$hard" ]] && echo "  hard:  POST  /tasks/$task/force-delete.json  (IRREVERSIBLE — releases DL ref)"
        return 0
    fi

    # Confirm the destructive path FIRST — before any deletion — so declining (or
    # a non-interactive shell without --yes) leaves the card fully live, never in a
    # half-trashed state. A non-TTY with no --yes refuses rather than reading a
    # confirmation from a stream that carries none (fail-closed on irreversibility).
    if [[ -n "$hard" && -z "$yes" ]]; then
        if [[ ! -t 0 ]]; then
            echo "kbcard: --hard requires --yes in a non-interactive shell (refusing to permanently delete without an explicit confirmation)" >&2
            return 2
        fi
        # `|| ans=""` so an EOF (Ctrl-D) at the prompt takes the graceful abort
        # path (read returns non-zero on EOF, which set -e would otherwise fatal).
        read -r -p "HARD-delete task $task PERMANENTLY (cascades subtasks/comments/links; releases DL ref; irreversible)? [y/N] " ans || ans=""
        [[ "$ans" == [yY] ]] || { echo "kbcard: aborted — task $task left live (not deleted)"; return 0; }
    fi

    kb_api PATCH "/tasks/$task.json" '{"_action":"delete"}' >/dev/null \
        || { echo "kbcard: soft-delete failed for task $task" >&2; return 1; }
    if [[ -z "$hard" ]]; then
        echo "kbcard: task $task soft-deleted (recoverable within the retention window; DL ref RETAINED — use --hard to release it)"
        return 0
    fi
    kb_api POST "/tasks/$task/force-delete.json" '' >/dev/null \
        || { echo "kbcard: force-delete failed for task $task (needs task.delete / admin). The card is now SOFT-DELETED (in the trash, recoverable) — retry --hard with an admin token, or restore it." >&2; return 1; }
    echo "kbcard: task $task HARD-deleted (permanent; DL ref released)"
}

main() {
    # Optional global `--board NAME` before the subcommand selects the board env.
    local board_name=""
    if [[ "${1:-}" == "--board" ]]; then
        board_name="${2:-}"
        shift 2
    fi
    # Resolves board env + host env + token; sets KB_API / KB_BOARD_ID / KB_TOKEN.
    kb_load_config "$board_name" || exit 2

    local cmd="${1:-}"
    [[ -z "$cmd" ]] && { sed -n '/^# Usage:/,/^$/p' "$0" | sed 's/^# //'; exit 0; }
    shift
    case "$cmd" in
        create-card) cmd_create_card "$@" ;;
        move)        cmd_move "$@" ;;
        patch)       cmd_patch "$@" ;;
        list)        cmd_list "$@" ;;
        link)        cmd_link "$@" ;;
        show)        cmd_show "$@" ;;
        archive)     cmd_archive "$@" ;;
        delete)      cmd_delete "$@" ;;
        *) echo "kbcard: unknown command '$cmd'" >&2; exit 2 ;;
    esac
}

# run main only when executed directly, so tests/kbcard-selftest.sh can source the pure fns.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then main "$@"; fi
