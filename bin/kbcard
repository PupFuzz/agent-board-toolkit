#!/usr/bin/env bash
# kbcard — thin wrapper for the kanban-board production board API
# Lives outside the kanbanboard repo. Token path + board state live in
# ~/.kanban-dev-token and ~/.kanban-dev-board.env so the script is portable.
#
# Usage:
#   kbcard create-card --type <alias> --name "title" \
#                      --column backlog|prioritized|in_progress|in_review|held|shipped_to_dev|released_to_main|wont_do \
#     <alias> is config-driven: any KB_TYPE_<ALIAS> in the board env writes that
#     native card_type_id; an unset/`000` alias (or KB_TYPING_MODE=tags) instead
#     omits card_type_id and tags the card `type:<alias>` — so create-card/list work
#     on native, all-tag, and mixed boards alike.
#                      [--description "..."] [--tags "tag1,tag2"] [--external-id "dl-093"] \
#                      [--dl "DL-093"] [--pr 178] [--pr-url URL] [--version "v0.9.2"] [--origin preemptive|consumer-driven|incident-triggered|user-requested]
#   kbcard move --task ID-OR-EXT --column COLUMN
#   kbcard patch --task ID-OR-EXT [--pr N] [--pr-url URL] [--version VER] [--column COL] [--description "..."] [--dl DL-NNN] [--triaged]
#     --pr-url writes payload.pr_url — the kanban derives a card's by-ref `source` (owner/repo)
#     from it; required for the repo-qualified PR→card lookup on a multi-repo board (--pr alone
#     sets pr_number, not source). Pre-PR placeholder: https://github.com/<owner>/<repo>/pull/0
#   kbcard list  [--column COL] [--type TYPE]
#   kbcard link --from TASK --to TASK --relation "bundles"|"blocks"|"caused"
#   kbcard show --task ID-OR-EXT
#
# Source of truth for IDs:
#   ~/.kanban-dev-board.env — sourced for stage/type/cf ID lookups.

set -euo pipefail

BOARD_ENV="${KBCARD_BOARD_ENV:-$HOME/.kanban-dev-board.env}"
LOG_FILE="${KBCARD_LOG_FILE:-$HOME/.kbcard-failures.log}"

# BOARD_ENV is sourced in main() after the optional `--board NAME` global flag
# is parsed (default: the kanban-board dev board). A second board (e.g. bridge)
# lives in ~/.kanban-<name>-board.env with its own KB_BOARD_ID / stage / type /
# cf IDs. Card types are per-board: `native_type_id` resolves a `--type` alias to
# KB_TYPE_<ALIAS> from the board env (any alias), writing the native id when present
# and falling back to a `type:<alias>` tag when the board lacks that native type —
# so an alias absent on one board (`fr` on kanban, `request`/`idea` on bridge) is
# tagged, not rejected. (`stage_id` still rejects an unknown column — stages are
# required.)

# API base is board-independent and is NOT baked into this shared tool — it is
# read from ~/.kanban-host.env (override the path via $KANBAN_HOST_ENV). See
# agent-board-toolkit docs/INSTALL.md.
HOST_ENV="${KANBAN_HOST_ENV:-$HOME/.kanban-host.env}"
if [[ -z "${KBCARD_API:-}" && -r "$HOST_ENV" ]]; then
    # shellcheck disable=SC1090
    source "$HOST_ENV"
fi
API="${KBCARD_API:?KBCARD_API not set — create ~/.kanban-host.env (see agent-board-toolkit docs/INSTALL.md)}"

# TOKEN_FILE is resolved AFTER the host env and the board env are sourced (in
# main(), via resolve_token), so a KBCARD_TOKEN_FILE set INSIDE a config file is
# honored — matching next-dl/board-snapshot. Resolving it at the top (before any
# source) silently ignored a config-file value. Precedence: a value from the
# last-sourced config wins, else the process env, else the hardcoded default.
TOKEN=""
resolve_token() {
    local token_file="${KBCARD_TOKEN_FILE:-$HOME/.kanban-dev-token}"
    if [[ ! -r "$token_file" ]]; then
        echo "kbcard: token file not readable: $token_file" >&2
        exit 2
    fi
    TOKEN="$(cat "$token_file")"
}

api() {
    local method="$1" path="$2" body="${3:-}"
    local args=(-sS -X "$method" -H "Authorization: Bearer $TOKEN" -H "Accept: application/json")
    if [[ -n "$body" ]]; then
        args+=(-H "Content-Type: application/json" --data "$body")
    fi
    local out http
    out="$(curl "${args[@]}" -w "\n__HTTP__%{http_code}" "$API$path" 2>&1)" || {
        echo "$(date -u +%FT%TZ) $method $path FAILED-CURL $out" >> "$LOG_FILE"
        echo "kbcard: curl failed" >&2; return 1
    }
    http="${out##*__HTTP__}"
    body="${out%__HTTP__*}"
    if [[ "$http" -ge 400 ]]; then
        echo "$(date -u +%FT%TZ) $method $path HTTP-$http $body" >> "$LOG_FILE"
        echo "kbcard: HTTP $http on $method $path" >&2
        echo "$body" >&2
        return 1
    fi
    printf '%s' "$body"
}

stage_id() {
    local id
    case "$1" in
        backlog) id="${KB_STAGE_BACKLOG:-}" ;;
        prioritized) id="${KB_STAGE_PRIORITIZED:-}" ;;
        in_progress) id="${KB_STAGE_IN_PROGRESS:-}" ;;
        in_review) id="${KB_STAGE_IN_REVIEW:-}" ;;
        held) id="${KB_STAGE_HELD:-}" ;;
        shipped_to_dev) id="${KB_STAGE_SHIPPED_TO_DEV:-}" ;;
        released_to_main) id="${KB_STAGE_RELEASED_TO_MAIN:-}" ;;
        wont_do) id="${KB_STAGE_WONT_DO:-}" ;;
        *) echo "kbcard: unknown column '$1'" >&2; return 2 ;;
    esac
    [[ -z "$id" ]] && { echo "kbcard: column '$1' is not defined on this board" >&2; return 2; }
    echo "$id"
}
# Resolve a --type alias to the board's NATIVE card_type_id, config-driven from
# KB_TYPE_<ALIAS> in the board env — ANY alias, not a hardcoded six (so a board's
# own taxonomy, e.g. KB_TYPE_TECH_DEBT, types all its cards). Prints the id ONLY
# when the board has a real native type for the alias; prints nothing when the
# caller should fall back to a `type:<alias>` tag — i.e. the alias is unset/`000`,
# or KB_TYPING_MODE=tags forces tag mode. NEVER fails: a board with no native types
# (all-tag) or only some (mixed) is a supported shape, not an error. This
# generalizes the BR-3.3 field-skip (version_target) from custom fields to types.
native_type_id() {
    [[ "${KB_TYPING_MODE:-}" == "tags" ]] && return 0   # forced tag mode → no native id
    local var id
    var="KB_TYPE_$(printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_')"
    id="${!var:-}"
    # A real native id is a positive integer; "", "0", "000", non-numeric ⇒ tag fallback.
    [[ "$id" =~ ^[0-9]+$ && "$id" -gt 0 ]] && printf '%s' "$id"
    return 0
}

# Normalize any DL input — `93`, `dl-93`, `DL-0093`, `DL-9001` — to the ONE canonical
# stored form `DL-NNN`, zero-padded to >=4 (matching next-dl's DL-%04d; 4 because adopter
# boards may already be near/over DL-999). Fixes the write-site so payload.dl_number is a
# single format (#3400, canon #5): kbcard previously wrote --dl verbatim, so a bare-int
# `--dl 93` stored `93`, which a `DL-[0-9]+` reader silently dropped. Width is cosmetic —
# every reader extracts digits and compares numerically — so the pre-existing 3-padded cards
# stay valid. Fails (exit 2) on an input with no number.
canon_dl() {
    # Accept ONLY a DL-shaped value — optional DL-/dl- prefix, optional leading zeros, then
    # 1–6 digits — anchored. A pr_url / version / hex string fat-fingered into --dl must FAIL
    # loudly, not silently become a plausible-but-wrong DL (a free `grep -oE '[0-9]+'` grabbed
    # the first digit run anywhere — e.g. a PR URL → DL-<pr#>; review #3400). The {1,6} bound
    # also keeps the base-10 arithmetic below inside int range.
    [[ "$1" =~ ^([Dd][Ll]-?)?0*([0-9]{1,6})$ ]] \
        || { echo "kbcard: --dl '$1' is not a DL number (expect e.g. DL-093 or 93)" >&2; return 2; }
    local n="$((10#${BASH_REMATCH[2]}))"   # 10# forces base-10 so a zero-padded value isn't read as octal
    [[ "$n" -ge 1 ]] || { echo "kbcard: --dl '$1' resolves to 0 — not a valid DL number" >&2; return 2; }
    printf 'DL-%04d' "$n"   # zero-pad to >=4 (next-dl matches); adopter boards may already be near/over DL-999
}

# Resolve a "task ref" to a numeric task id.
#   Numeric → returned as-is.
#   Non-numeric → looked up by external_id on the board (search endpoint).
resolve_task() {
    local ref="$1"
    if [[ "$ref" =~ ^[0-9]+$ ]]; then
        [[ "$ref" -ge 1 ]] || { echo "kbcard: invalid task id '$ref'" >&2; exit 1; }
        echo "$ref"; return 0
    fi
    local id
    id="$(api GET "/tasks/search.json?q=board_id=$KB_BOARD_ID%20external_id:$ref" | jq -r '.data[0].id // empty')"
    if [[ -z "$id" || "$id" == "null" ]]; then
        echo "kbcard: no task found with external_id='$ref' on board $KB_BOARD_ID" >&2; return 1
    fi
    [[ "$id" =~ ^[0-9]+$ && "$id" -ge 1 ]] || { echo "kbcard: invalid task id '$id'" >&2; exit 1; }
    echo "$id"
}

cmd_create_card() {
    local type="" name="" column="backlog" desc="" tags="" ext_id="" dl="" pr="" pr_url="" version="" origin=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type) type="$2"; shift 2 ;;
            --name) name="$2"; shift 2 ;;
            --column) column="$2"; shift 2 ;;
            --description) desc="$2"; shift 2 ;;
            --tags) tags="$2"; shift 2 ;;
            --external-id) ext_id="$2"; shift 2 ;;
            --dl) dl="$2"; shift 2 ;;
            --pr) pr="$2"; shift 2 ;;
            --pr-url) pr_url="$2"; shift 2 ;;
            --version) version="$2"; shift 2 ;;
            --origin) origin="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$name" ]] && { echo "kbcard: --name required" >&2; return 2; }
    [[ -z "$type" ]] && { echo "kbcard: --type required" >&2; return 2; }
    # The alias maps to KB_TYPE_<NAME> and (on a non-native board) a `type:<name>`
    # tag, so it must be tag-safe — reject commas/spaces that would corrupt the CSV.
    [[ "$type" =~ ^[A-Za-z0-9_-]+$ ]] || { echo "kbcard: --type '$type' must be alphanumeric / '-' / '_'" >&2; return 2; }

    local stage type_id payload_args=()
    stage="$(stage_id "$column")"
    type_id="$(native_type_id "$type")"
    # Tag fallback (generalizes BR-3.3): a board with no native type for this alias
    # (all-tag, mixed, or KB_TYPING_MODE=tags) gets a `type:<alias>` tag instead of a
    # bad card_type_id:0. The native path (real id) is unchanged.
    [[ -z "$type_id" ]] && tags="${tags:+$tags,}type:${type}"

    if [[ -n "$dl" ]]; then dl="$(canon_dl "$dl")" || return 2; payload_args+=("dl_number=$dl"); fi
    [[ -n "$pr" ]]      && payload_args+=("pr_number=$pr")
    [[ -n "$pr_url" ]]  && payload_args+=("pr_url=$pr_url")   # sets the by-ref `source` (owner/repo); pr_number does not
    # BR-3.3: only write version_target if the board actually has that custom field
    # (its id declared as KB_CF_VERSION_TARGET in the board env) — else the write
    # 422s (kanban gates payload keys to registered fields). Warn, don't drop
    # silently, so a misconfigured board surfaces instead of vanishing the value.
    if [[ -n "$version" ]]; then
        if [[ -n "${KB_CF_VERSION_TARGET:-}" && "${KB_CF_VERSION_TARGET}" != "000" ]]; then
            payload_args+=("version_target=$version")
        else
            echo "kbcard: --version ignored — this board has no version_target field (declare KB_CF_VERSION_TARGET in its board env to enable)" >&2
        fi
    fi
    [[ -n "$origin" ]]  && payload_args+=("origin=$origin")

    # Build payload as a JSON object. Coerce numeric strings to JSON numbers so
    # number-typed custom fields (e.g. pr_number) don't 422 with "Must be a number".
    local payload_json="{}"
    if [[ ${#payload_args[@]} -gt 0 ]]; then
        payload_json="$(printf '%s\n' "${payload_args[@]}" | jq -R 'capture("^(?<k>[^=]+)=(?<v>.*)$") | {(.k): (.v | tonumber? // .)}' | jq -s 'add')"
    fi

    # Build inner task object; POST body wraps it in {task: ...} per V3 API contract.
    local body
    body="$(jq -n \
        --arg name "$name" \
        --argjson board "$KB_BOARD_ID" \
        --argjson stage "$stage" \
        --arg type_id "$type_id" \
        --arg desc "$desc" \
        --arg tags "$tags" \
        --arg ext_id "$ext_id" \
        --argjson payload "$payload_json" \
        '{name: $name, board_id: $board, workflow_stage_id: $stage}
         + (if $type_id != "" then {card_type_id: ($type_id | tonumber)} else {} end)
         + (if $desc  != "" then {description: $desc} else {} end)
         + (if $tags  != "" then {tags: ($tags | split(","))} else {} end)
         + (if $ext_id != "" then {external_id: ($ext_id | tonumber? // null)} else {} end)
         + (if ($payload | length) > 0 then {payload: $payload} else {} end)
         | {task: .}')"

    api POST "/tasks.json" "$body" | jq '.data | {id, name, workflow_stage_id, payload}'
}

cmd_move() {
    local task_ref="" column=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            --column) column="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$task_ref" || -z "$column" ]] && { echo "kbcard: --task and --column required" >&2; return 2; }
    local task stage body
    task="$(resolve_task "$task_ref")"
    stage="$(stage_id "$column")"
    body="$(jq -n --argjson stage "$stage" '{task: {workflow_stage_id: $stage}}')"
    api PATCH "/tasks/$task.json" "$body" | jq '.data | {id, name, workflow_stage_id}'
}

cmd_patch() {
    local task_ref="" pr="" pr_url="" version="" column="" desc="" dl="" triaged=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            --pr) pr="$2"; shift 2 ;;
            --pr-url) pr_url="$2"; shift 2 ;;
            --version) version="$2"; shift 2 ;;
            --column) column="$2"; shift 2 ;;
            --description) desc="$2"; shift 2 ;;
            --dl) dl="$2"; shift 2 ;;
            --triaged) triaged=1; shift ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$task_ref" ]] && { echo "kbcard: --task required" >&2; return 2; }
    local task; task="$(resolve_task "$task_ref")"

    local payload_args=()
    [[ -n "$pr" ]]      && payload_args+=("pr_number=$pr")
    # pr_url sets payload.pr_url, from which the kanban derives a card's by-ref `source`
    # (owner/repo, lowercased) — required for the repo-qualified PR→card lookup on a
    # multi-repo board; pr_number alone does NOT set source. Pre-PR placeholder form is
    # .../pull/0 (the repo segment is what matters; the poll reconciler overwrites the URL).
    [[ -n "$pr_url" ]]  && payload_args+=("pr_url=$pr_url")
    # BR-3.3: only write version_target if the board actually has that custom field
    # (its id declared as KB_CF_VERSION_TARGET in the board env) — else the write
    # 422s (kanban gates payload keys to registered fields). Warn, don't drop
    # silently, so a misconfigured board surfaces instead of vanishing the value.
    if [[ -n "$version" ]]; then
        if [[ -n "${KB_CF_VERSION_TARGET:-}" && "${KB_CF_VERSION_TARGET}" != "000" ]]; then
            payload_args+=("version_target=$version")
        else
            echo "kbcard: --version ignored — this board has no version_target field (declare KB_CF_VERSION_TARGET in its board env to enable)" >&2
        fi
    fi
    if [[ -n "$dl" ]]; then dl="$(canon_dl "$dl")" || return 2; payload_args+=("dl_number=$dl"); fi

    local body inner='{}'
    if [[ ${#payload_args[@]} -gt 0 ]]; then
        local new_payload cur_payload payload_json
        # Coerce numeric strings (pr_number is a number-typed custom field).
        new_payload="$(printf '%s\n' "${payload_args[@]}" | jq -R 'capture("^(?<k>[^=]+)=(?<v>.*)$") | {(.k): (.v | tonumber? // .)}' | jq -s 'add')"
        # MERGE with the existing payload: the kanban API replaces `payload`
        # WHOLESALE, so a bare {pr_number} would wipe dl_number/origin/etc.
        # Read-merge-write to preserve the other custom fields.
        # `// {}` only catches null/false; an empty payload comes back as `[]`
        # (PHP serializes an empty assoc array as a JSON array), and `[] + {new}`
        # errors in jq. Normalize any non-object payload to {} before merging.
        cur_payload="$(api GET "/tasks/$task.json" | jq '.data.payload | if type == "object" then . else {} end')"
        payload_json="$(jq -n --argjson cur "$cur_payload" --argjson new "$new_payload" '$cur + $new')"
        inner="$(jq -n --argjson p "$payload_json" '{payload: $p}')"
    fi
    if [[ -n "$column" ]]; then
        local stage; stage="$(stage_id "$column")"
        inner="$(jq -n --argjson cur "$inner" --argjson stage "$stage" '$cur + {workflow_stage_id: $stage}')"
    fi
    if [[ -n "$desc" ]]; then
        inner="$(jq -n --argjson cur "$inner" --arg d "$desc" '$cur + {description: $d}')"
    fi
    if [[ -n "$triaged" ]]; then
        # tags are a top-level string list, replaced WHOLESALE by the API — so
        # read-merge-write to add `triaged` without dropping existing tags.
        local cur_tags new_tags
        cur_tags="$(api GET "/tasks/$task.json" | jq '.data.tags // []')"
        new_tags="$(jq -n --argjson cur "$cur_tags" '($cur + ["triaged"]) | unique')"
        inner="$(jq -n --argjson cur "$inner" --argjson tags "$new_tags" '$cur + {tags: $tags}')"
    fi
    body="$(jq -n --argjson t "$inner" '{task: $t}')"
    api PATCH "/tasks/$task.json" "$body" | jq '.data | {id, name, workflow_stage_id, payload, description: (.description // "" | .[0:80])}'
}

cmd_list() {
    local column="" type=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --column) column="$2"; shift 2 ;;
            --type) type="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    # TaskSearch DSL doesn't expose workflow_stage_id / card_type_id directly —
    # by design, not a bug. workflow_stage_id was explicitly declined per sola-pm
    # 2026-05-19 (client-side filtering deemed sufficient); card_type: is on the
    # DL-013 long-tail list as a candidate-if-asked. Filter client-side via jq.
    local q="board_id=$KB_BOARD_ID"
    local stage_filter type_filter
    if [[ -n "$column" ]]; then stage_filter="$(stage_id "$column")"; fi
    if [[ -n "$type" ]];   then type_filter="$(native_type_id "$type")"; fi

    # Paginate the fetch BEFORE filtering. search.json returns the DL-146
    # {data, meta, links} envelope, page-based — reading only page 1 silently
    # UNDERCOUNTS every column once a board exceeds one page. Read page 1 for
    # meta.last_page, then accumulate each page's compact .data line into a shell
    # variable and slurp+concatenate via `jq -s 'add'` over STDIN.
    #
    # Two failure modes this shape avoids:
    #   - argv overflow: the dataset never reaches argv. A single argv entry caps
    #     at MAX_ARG_STRLEN (128 KiB) — well under a multi-page board's JSON — so
    #     the v0.4.3 `--argjson acc "$data"` accumulator died with "Argument list
    #     too long" on a large page (#3091). `$pages` lives in shell memory; the
    #     final `printf | jq` feeds it via STDIN (printf is a builtin → no exec).
    #   - silent truncation: every api/jq call runs at plain function-body level
    #     (NOT inside a pipeline), so set -e actually aborts the whole command on a
    #     failed page fetch. (A `{ … } | jq` brace group runs the loop in a pipe
    #     subshell where set -e is suppressed for non-final commands — a failed
    #     page-2+ fetch would be swallowed and a truncated list returned, exit 0.)
    # Only the tiny scalar filters go via --argjson. limit=200 is the server max.
    local page1 last_page p page_n pages
    page1="$(api GET "/tasks/search.json?q=$q&limit=200&page=1")"
    last_page="$(printf '%s' "$page1" | jq -r '.meta.last_page // 1')"
    if [[ "$last_page" -gt "${BOARD_PAGE_CAP:-50}" ]]; then
        echo "kbcard: result set exceeded BOARD_PAGE_CAP=${BOARD_PAGE_CAP:-50} pages (last_page=$last_page) — raise BOARD_PAGE_CAP or narrow the query" >&2
        exit 1
    fi
    pages="$(printf '%s' "$page1" | jq -c '.data // []')"
    for (( p = 2; p <= last_page; p++ )); do
        page_n="$(api GET "/tasks/search.json?q=$q&limit=200&page=$p")"
        pages+=$'\n'"$(printf '%s' "$page_n" | jq -c '.data // []')"
    done
    # --type resolves per alias by board capability: when the board has a NATIVE id
    # for the alias ($type != null) match card_type_id; otherwise ($type == null —
    # all-tag/mixed/KB_TYPING_MODE) match the `type:<alias>` tag. The two clauses are
    # MUTUALLY EXCLUSIVE — gating the tag clause on `$type == null` avoids both (a) an
    # all-tag board matching every null-typed card, and (b) a native board surfacing a
    # differently-typed card that carries a stray type:<alias> tag.
    printf '%s\n' "$pages" | jq -s \
        --argjson stage "${stage_filter:-null}" \
        --argjson type "${type_filter:-null}" \
        --arg typetag "${type:+type:$type}" \
        '(add // [])
         | map(select(($stage == null or .workflow_stage_id == $stage)
                and ($typetag == ""
                     or ($type != null and .card_type_id == $type)
                     or ($type == null and ((.tags // []) | index($typetag)) != null))))
         | map(.payload = (if (.payload | type) == "object" then .payload else {} end))
         | map({id, name, stage: .workflow_stage_id, type: .card_type_id, dl: .payload.dl_number, pr: .payload.pr_number})'
}

cmd_link() {
    local from="" to="" relation=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from) from="$2"; shift 2 ;;
            --to) to="$2"; shift 2 ;;
            --relation) relation="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    [[ -z "$from" || -z "$to" || -z "$relation" ]] && { echo "kbcard: --from --to --relation required" >&2; return 2; }
    local f t body
    f="$(resolve_task "$from")"
    t="$(resolve_task "$to")"
    body="$(jq -n --argjson from "$f" --argjson to "$t" --arg rel "$relation" '{from_task_id: $from, to_task_id: $to, relation_type: $rel}')"
    api POST "/task_links.json" "$body" | jq '.data'
}

cmd_show() {
    local task_ref=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --task) task_ref="$2"; shift 2 ;;
            *) echo "kbcard: unknown arg '$1'" >&2; return 2 ;;
        esac
    done
    local task; task="$(resolve_task "$task_ref")"
    api GET "/tasks/$task.json" | jq '.data'
}

main() {
    # Optional global `--board NAME` before the subcommand selects the board env.
    if [[ "${1:-}" == "--board" ]]; then
        case "${2:-}" in
            bridge) BOARD_ENV="$HOME/.kanban-bridge-board.env" ;;
            kanban|dev|"") BOARD_ENV="$HOME/.kanban-dev-board.env" ;;
            *) BOARD_ENV="$HOME/.kanban-${2}-board.env" ;;
        esac
        shift 2
    fi
    if [[ ! -r "$BOARD_ENV" ]]; then
        echo "kbcard: board env file not readable: $BOARD_ENV" >&2
        exit 2
    fi
    # shellcheck disable=SC1090
    source "$BOARD_ENV"
    resolve_token   # after host + board env are sourced, so a config-file KBCARD_TOKEN_FILE is honored

    local cmd="${1:-}"
    [[ -z "$cmd" ]] && { sed -n '/^# Usage:/,/^$/p' "$0" | sed 's/^# //'; exit 0; }
    shift
    case "$cmd" in
        create-card) cmd_create_card "$@" ;;
        move)        cmd_move "$@" ;;
        patch)       cmd_patch "$@" ;;
        list)        cmd_list "$@" ;;
        link)        cmd_link "$@" ;;
        show)        cmd_show "$@" ;;
        *) echo "kbcard: unknown command '$cmd'" >&2; exit 2 ;;
    esac
}

main "$@"
