#!/usr/bin/env bash
# board-snapshot — compact in-flight summary of the dev tracking boards, so the
# BOARD (not memory) is the source of truth surfaced at SessionStart. Read-only,
# fail-soft: a slow/down API prints a notice and exits 0, never blocking startup.
#
# Boards: 5 = kanban-board ("Kanban Product Backlog"), 8 = agent-webhook-bridge.
set -uo pipefail

# API base + token path read from ~/.kanban-host.env (board-independent; not
# baked in). kb_load_host_token sources the host env (for a KBCARD_TOKEN_FILE
# override + API base) and reads the token; fail-soft — a missing token → exit 0
# so a missing config never blocks SessionStart. See INSTALL.md.
# shellcheck source=bin/_kb-board-lib.sh
source "$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/_kb-board-lib.sh"
kb_load_host_token || exit 0
API="${KB_API:-https://YOUR-KANBAN-HOST/api/v3}"
TOKEN="$KB_TOKEN"
# Cap each page fetch at 5s so a slow/down API never stalls SessionStart (the
# shared fetch_board_cards honors KB_CURL_MAX_TIME).
KB_CURL_MAX_TIME=5

# The whole-board paginated read is the shared fetch_board_cards (lib): reading
# only the server's default page silently shortened the in-flight + untriaged
# lists once a board grew past it (board 5 is already ~98 cards). A page-cap hit
# (rc 3) still yields the partial array, so this fail-soft SessionStart display
# shows what it has rather than going dark.

snap() {  # $1 = board env file   $2 = label
  local envf="$1" label="$2"
  [[ -r "$envf" ]] || { echo "• ${label}: (env $envf missing)"; return 0; }
  (
    # shellcheck disable=SC1090
    source "$envf"
    local data rc
    data="$(fetch_board_cards "$API" "$TOKEN" "$KB_BOARD_ID" "${SNAPSHOT_PAGE_CAP:-25}")"; rc=$?
    [[ $rc -eq 0 || $rc -eq 3 ]] \
        || { echo "• ${label}: (board API unreachable)"; return 0; }
    # in-flight = In Progress + In Review + Held (Held only exists on the bridge board)
    local names
    names="$(jq -n \
        --arg ip "${KB_STAGE_IN_PROGRESS:-}" \
        --arg ir "${KB_STAGE_IN_REVIEW:-}" \
        --arg hl "${KB_STAGE_HELD:-}" \
        '{($ip):"In Progress",($ir):"In Review"}
         + (if $hl!="" then {($hl):"Held"} else {} end)
         | with_entries(select(.key!=""))')"
    printf '%s' "$data" | jq -r --arg label "$label" --argjson names "$names" '
        (. // []) as $t
        | ($names | keys | map(tonumber)) as $infl
        | "• \($label): in-flight \([$t[]|select(.workflow_stage_id as $s|$infl|index($s))]|length)",
          ([$t[] | select(.workflow_stage_id as $s | $infl | index($s))
            | "    #\(.id) [\($names[(.workflow_stage_id|tostring)])] \(.name[0:68])"] | .[])
      ' 2>/dev/null || echo "• ${label}: (parse error)"
  )
}

# Untriaged = a card NOT in a terminal column (Shipped/Released/Won't-Do) and
# lacking the `triaged` tag. New cards land untagged → surface here so triage is
# never silently missed (the agreed "triaged is a separate signal from the DL
# number" model). A Won't-Do card is processed-to-completion (a terminal
# disposition), so it is terminal here too — never flagged untriaged.
# The /triage-cards skill is the codified procedure to clear them.
untriaged() {  # $1 = board env file   $2 = label
  local envf="$1" label="$2"
  [[ -r "$envf" ]] || return 0
  (
    # shellcheck disable=SC1090
    source "$envf"
    local data rc
    data="$(fetch_board_cards "$API" "$TOKEN" "$KB_BOARD_ID" "${SNAPSHOT_PAGE_CAP:-25}")"; rc=$?   # paginates + warns loud-on-cap/short-read
    [[ $rc -eq 0 || $rc -eq 3 ]] || return 0
    printf '%s' "$data" | jq -r --arg label "$label" \
        --arg shipped "${KB_STAGE_SHIPPED_TO_DEV:-}" \
        --arg released "${KB_STAGE_RELEASED_TO_MAIN:-}" \
        --arg wontdo "${KB_STAGE_WONT_DO:-}" '
        ([$shipped, $released, $wontdo] | map(select(. != "") | tonumber)) as $term
        | ((. // [])
           | map(select(((.workflow_stage_id as $s | $term | index($s)) | not)
                        and (((.tags // []) | index("triaged")) | not)))
           | sort_by(.id) | reverse) as $u
        | if ($u | length) > 0 then
            "⚠ \($label): \($u | length) UNTRIAGED — run the /triage-cards skill (newest first):",
            ($u[0:6][] | "    #\(.id) [stage \(.workflow_stage_id)] \(.name[0:60])"),
            (if ($u | length) > 6 then "    … +\(($u | length) - 6) more" else empty end)
          else empty end
      ' 2>/dev/null
  )
}

# Board roster is config-driven (BR-1), mirroring kbcard's `--board <name>` model
# so a PM-project adopter drives its OWN boards (not kanban-dev's hardcoded two).
# `~/.kanban-snapshot-boards` (override via KANBAN_SNAPSHOT_BOARDS): one
# `<name>:<label>` per line (`#` comments / blanks skipped); `<name>` resolves to
# `~/.kanban-<name>-board.env`, `<label>` is the display string (defaults to the
# name if no `:`). Absent/empty ⇒ the kanban-dev default below — back-compatible.
SNAPSHOT_BOARDS="${KANBAN_SNAPSHOT_BOARDS:-$HOME/.kanban-snapshot-boards}"
roster=()   # each entry: "<envfile>\t<label>"
if [[ -r "$SNAPSHOT_BOARDS" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line#"${line%%[![:space:]]*}"}"   # ltrim
        [[ -z "$line" || "$line" == \#* ]] && continue
        name="${line%%:*}"
        label="${line#*:}"
        [[ "$label" == "$line" ]] && label="$name"   # no colon ⇒ label = name
        name="${name//[[:space:]]/}"
        [[ -z "$name" ]] && continue
        roster+=("$HOME/.kanban-${name}-board.env"$'\t'"$label")
    done < "$SNAPSHOT_BOARDS"
fi
if [[ ${#roster[@]} -eq 0 ]]; then
    roster=(
        "$HOME/.kanban-dev-board.env"$'\t'"Board 5 (kanban-board)"
        "$HOME/.kanban-bridge-board.env"$'\t'"Board 8 (bridge)"
    )
fi

echo "── Dev board snapshot — boards are the source of truth (memory is a cache) ──"
for entry in "${roster[@]}"; do snap "${entry%%$'\t'*}" "${entry#*$'\t'}"; done
echo "── Untriaged cards — triage is my responsibility; none may be silently missed ──"
for entry in "${roster[@]}"; do untriaged "${entry%%$'\t'*}" "${entry#*$'\t'}"; done
exit 0
