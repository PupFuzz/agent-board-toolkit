#!/usr/bin/env bash
# board-snapshot — compact in-flight summary of the dev tracking boards, so the
# BOARD (not memory) is the source of truth surfaced at SessionStart. Read-only,
# fail-soft: a slow/down API prints a notice and exits 0, never blocking startup.
#
# Boards: 5 = kanban-board ("Kanban Product Backlog"), 8 = agent-webhook-bridge.
set -uo pipefail

# API base read from ~/.kanban-host.env (board-independent; not baked in) via
# kb_load_host_env, which also publishes KB_HOST_TOKEN_FILE — the host-level token
# default. The TOKEN IS NOT READ HERE: each board may point KBCARD_TOKEN_FILE at its
# own token, so it is read per-board inside snap()/untriaged() below. Reading one
# token up-front and exiting when it was missing meant a host that uses only
# per-board tokens (no ~/.kanban-dev-token) rendered NOTHING at SessionStart.
# Fail-soft throughout — a missing config never blocks SessionStart. See INSTALL.md.
KB_LIB="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)/_kb-board-lib.sh"
[ -r "$KB_LIB" ] || { echo "$(basename "${BASH_SOURCE[0]}"): shared lib _kb-board-lib.sh not found next to this script — reinstall per INSTALL.md §3 (symlink all of bin/), or vendor _kb-board-lib.sh alongside this tool." >&2; exit 1; }
# shellcheck source=bin/_kb-board-lib.sh
source "$KB_LIB"
kb_load_host_env   # cannot fail (reads no token)
API="${KB_API:-https://YOUR-KANBAN-HOST/api/v3}"
# Cap each page fetch at 5s so a slow/down API never stalls SessionStart (the
# shared fetch_board_cards honors KB_CURL_MAX_TIME).
KB_CURL_MAX_TIME=5

# The whole-board paginated read is the shared fetch_board_cards (lib): reading
# only the server's default page silently shortened the in-flight + untriaged
# lists once a board grew past it (board 5 is already ~98 cards). A page-cap hit
# (rc 3) still yields the partial array, so this fail-soft SessionStart display
# shows what it has rather than going dark.

snap() {  # $1 = board env file   $2 = label
  local envf="$1" label="$2"
  [[ -r "$envf" ]] || { echo "• ${label}: (env $envf missing)"; return 0; }
  (
    # Clean slate before sourcing: board envs EXPORT their keys, so an operator shell that
    # sourced one board's env carries that board's ids and token here. Without the unset, an
    # env that omits any of these silently inherits the other board's value — rendering the
    # WRONG board under this label (KB_BOARD_ID), or a stage id that means something else.
    # KBCARD_TOKEN_FILE is unset for the same reason plus one more: the host env's value is
    # in this shell (kb_load_host_env sourced it), and it must not read back as this board's
    # own override — the ladder below places it a tier lower.
    unset KBCARD_TOKEN_FILE KB_BOARD_ID KB_STAGE_IN_PROGRESS KB_STAGE_IN_REVIEW KB_STAGE_HELD
    # shellcheck disable=SC1090
    source "$envf"
    [[ -n "${KB_BOARD_ID:-}" ]] || { echo "• ${label}: (env $envf sets no KB_BOARD_ID)"; return 0; }
    # Explicit token ladder: this board's > the host's > the default. Per-board fail-soft —
    # one board's unreadable token must not blank the others.
    kb_read_token "${KBCARD_TOKEN_FILE:-${KB_HOST_TOKEN_FILE:-$HOME/.kanban-dev-token}}" \
        || { echo "• ${label}: (token file unreadable: ${KBCARD_TOKEN_FILE:-${KB_HOST_TOKEN_FILE:-$HOME/.kanban-dev-token}})"; return 0; }
    local data rc
    data="$(fetch_board_cards "$API" "$KB_TOKEN" "$KB_BOARD_ID" "${SNAPSHOT_PAGE_CAP:-25}")"; rc=$?
    [[ $rc -eq 0 || $rc -eq 3 || $rc -eq 4 ]] \
        || { echo "• ${label}: (board API unreachable)"; return 0; }
    # in-flight = the board's In Progress + In Review + Held stages, selected by the
    # env stage ids (the env is the contract for WHICH stages are in-flight; a board
    # omitting one simply drops it from the map).
    #
    # Display names are BOARD-SOURCED. They were hardcoded literals ("In Progress" /
    # "In Review" / "Held"), i.e. a private second copy of what the board calls its
    # columns — so a rename left the snapshot asserting a name the board no longer
    # used, and it printed [Held] for a column named Blocked/Gated on all three
    # boards. The two invisible siblings were the same defect: "In Progress" and
    # "In Review" only ever looked right because they happened to match.
    #
    # preload.json is the cheap stages read (~2.5KB, vs ~220KB for boards/{id}.json,
    # which inlines every task AND its description); there is no GET index for
    # workflow_stages, and tasks/search returns workflow_stage_id but no name.
    #
    # Fail-soft (SessionStart must never block): an unreachable preload, or an env
    # stage id the board doesn't define, degrades to "stage <id>" — the shape the
    # untriaged block below already prints. An unnamed stage is honest; a guessed
    # one is how this bug read as working.
    local names pre
    KB_API="$API"; KB_API_QUIET=1   # kb_api reads these globals; snap() body is a subshell, so this is contained
    pre="$(kb_api GET "/boards/$KB_BOARD_ID/preload.json" 2>/dev/null)" || pre=""
    # A 2xx body is not necessarily JSON — a proxy, captive portal, or truncated
    # response can answer 200 with HTML. --argjson ABORTS jq on invalid JSON, which
    # would empty $names and cascade into the card-listing jq below, collapsing the
    # whole board to "(parse error)". The cards fetched fine in that case; only their
    # LABELS are unknown, so a bad preload must cost the names and nothing else.
    printf '%s' "$pre" | jq -e . >/dev/null 2>&1 || pre=""
    names="$(jq -n \
        --arg ip "${KB_STAGE_IN_PROGRESS:-}" \
        --arg ir "${KB_STAGE_IN_REVIEW:-}" \
        --arg hl "${KB_STAGE_HELD:-}" \
        --argjson pre "${pre:-null}" \
        '($pre
          | if . == null then {}
            else ([.data.workflows[]?.stages[]? | {(.id|tostring): .name}] | add // {})
            end) as $bn
         | [$ip,$ir,$hl]
         | map(select(. != ""))
         | map({(.): ($bn[.] // ("stage " + .))})
         | add // {}')"
    printf '%s' "$data" | jq -r --arg label "$label" --argjson names "$names" '
        (. // []) as $t
        | ($names | keys | map(tonumber)) as $infl
        | "• \($label): in-flight \([$t[]|select(.workflow_stage_id as $s|$infl|index($s))]|length)",
          ([$t[] | select(.workflow_stage_id as $s | $infl | index($s))
            | "    #\(.id) [\($names[(.workflow_stage_id|tostring)])] \(.name[0:68])"] | .[])
      ' 2>/dev/null || echo "• ${label}: (parse error)"
  )
}

# Untriaged = a card NOT in a terminal column (Shipped/Released/Won't-Do) and
# lacking the `triaged` tag. New cards land untagged → surface here so triage is
# never silently missed (the agreed "triaged is a separate signal from the DL
# number" model). A Won't-Do card is processed-to-completion (a terminal
# disposition), so it is terminal here too — never flagged untriaged.
# The /triage-cards skill is the codified procedure to clear them.
untriaged() {  # $1 = board env file   $2 = label
  local envf="$1" label="$2"
  [[ -r "$envf" ]] || return 0
  (
    unset KBCARD_TOKEN_FILE   # see snap(): report THIS board's override, not the host's
    # shellcheck disable=SC1090
    source "$envf"
    # Silent on an unreadable token: snap() runs over the same roster first and already
    # reported it loudly — this would only be a second copy of the same line.
    kb_read_token "${KBCARD_TOKEN_FILE:-${KB_HOST_TOKEN_FILE:-$HOME/.kanban-dev-token}}" || return 0
    local data rc
    data="$(fetch_board_cards "$API" "$KB_TOKEN" "$KB_BOARD_ID" "${SNAPSHOT_PAGE_CAP:-25}")"; rc=$?   # paginates + warns loud-on-cap/short-read
    [[ $rc -eq 0 || $rc -eq 3 || $rc -eq 4 ]] || return 0
    printf '%s' "$data" | jq -r --arg label "$label" \
        --arg shipped "${KB_STAGE_SHIPPED_TO_DEV:-}" \
        --arg released "${KB_STAGE_RELEASED_TO_MAIN:-}" \
        --arg wontdo "${KB_STAGE_WONT_DO:-}" '
        ([$shipped, $released, $wontdo] | map(select(. != "") | tonumber)) as $term
        | ((. // [])
           | map(select(((.workflow_stage_id as $s | $term | index($s)) | not)
                        and (((.tags // []) | index("triaged")) | not)))
           | sort_by(.id) | reverse) as $u
        | if ($u | length) > 0 then
            "⚠ \($label): \($u | length) UNTRIAGED — run the /triage-cards skill (newest first):",
            ($u[0:6][] | "    #\(.id) [stage \(.workflow_stage_id)] \(.name[0:60])"),
            (if ($u | length) > 6 then "    … +\(($u | length) - 6) more" else empty end)
          else empty end
      ' 2>/dev/null
  )
}

# Board roster is config-driven (BR-1), mirroring kbcard's `--board <name>` model
# so a PM-project adopter drives its OWN boards (not kanban-dev's hardcoded two).
# `~/.kanban-snapshot-boards` (override via KANBAN_SNAPSHOT_BOARDS): one
# `<name>:<label>` per line (`#` comments / blanks skipped); `<name>` resolves to
# `~/.kanban-<name>-board.env`, `<label>` is the display string (defaults to the
# name if no `:`). Absent/empty ⇒ the kanban-dev default below — back-compatible.
SNAPSHOT_BOARDS="${KANBAN_SNAPSHOT_BOARDS:-$HOME/.kanban-snapshot-boards}"
roster=()   # each entry: "<envfile>\t<label>"
if [[ -r "$SNAPSHOT_BOARDS" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line#"${line%%[![:space:]]*}"}"   # ltrim
        [[ -z "$line" || "$line" == \#* ]] && continue
        name="${line%%:*}"
        label="${line#*:}"
        [[ "$label" == "$line" ]] && label="$name"   # no colon ⇒ label = name
        name="${name//[[:space:]]/}"
        [[ -z "$name" ]] && continue
        roster+=("$HOME/.kanban-${name}-board.env"$'\t'"$label")
    done < "$SNAPSHOT_BOARDS"
fi
if [[ ${#roster[@]} -eq 0 ]]; then
    roster=(
        "$HOME/.kanban-dev-board.env"$'\t'"Board 5 (kanban-board)"
        "$HOME/.kanban-bridge-board.env"$'\t'"Board 8 (bridge)"
    )
fi

echo "── Dev board snapshot — boards are the source of truth (memory is a cache) ──"
for entry in "${roster[@]}"; do snap "${entry%%$'\t'*}" "${entry#*$'\t'}"; done
echo "── Untriaged cards — triage is my responsibility; none may be silently missed ──"
for entry in "${roster[@]}"; do untriaged "${entry%%$'\t'*}" "${entry#*$'\t'}"; done

# Runtime staleness (cards #4351/#4361/#4393): the pin/copies topology fails silently in
# the worse direction — tools keep working, just older. --quiet prints nothing when
# current, so a healthy host stays silent.
#
# 2>&1 IS LOAD-BEARING: the guard writes warnings/failures to stderr, and this script's
# consumer is a SessionStart hook that surfaces STDOUT — a stderr-only warning is
# discarded and the guard silently never reaches anyone (the same channel trap
# board-card-start already ate: "the installed hook wrapper discards stderr, so the log
# is the durable record"). A staleness warning nobody reads is the exposure, not the fix.
# Folding to stdout puts it in the same stream as the board snapshot itself.
#
# Never blocks the snapshot (SessionStart is fail-soft): `|| true` swallows the guard's
# non-zero exit — the MESSAGE is the signal here, not the status.
command -v agent-board-toolkit-runtime-check >/dev/null 2>&1 \
    && agent-board-toolkit-runtime-check --quiet 2>&1 || true
exit 0
