#!/usr/bin/env bash
# PostToolUse(Bash) hook — AUTONOMOUS, SILENT board card mover.
#
# Goal: the hook does the work so the agent never has to process a reminder
# (zero token cost). Runs async (configured in settings.json) and injects NOTHING
# into the session.
#
# On a PR open whose title carries a DL-NNN, it moves that DL's card to In Review
# ITSELF. Match is by the card's dl_number on either board (DL numbers are unique
# across board 5 + board 8). The move is COLUMN-ONLY (workflow_stage_id) — it never
# sends `payload`, so it cannot corrupt custom fields.
#
# Card-existence is the filter: a PR whose title has no DL-NNN (docs/chore/
# dependabot/back-merge), or a DL with no card, is an INSTANT no-op with no API
# calls. merge->Shipped and branch->In Progress are intentionally NOT automated
# here: `gh pr merge N` carries no title to match on, and branch-cut card state is
# speculative — both are reconciled by the session-close ritual (board-session-close).
#
# Audit trail: ~/.board-sync.log.
set -uo pipefail
LOG="$HOME/.board-sync.log"
KB="$HOME/.local/bin/kbcard"

input="$(cat)"
cmd="$(printf '%s' "$input" | jq -r '.tool_input.command // ""' 2>/dev/null)" || exit 0
case "$cmd" in *"gh pr create"*) ;; *) exit 0 ;; esac

dl="$(printf '%s' "$cmd" | grep -oiE 'DL-[0-9]+' | head -1 | tr 'a-z' 'A-Z')"
[[ -z "$dl" ]] && exit 0   # no DL in the title → no card to move → silent

for board in bridge kanban; do
  flag=""; [[ "$board" == bridge ]] && flag="--board bridge"
  card="$($KB $flag list 2>/dev/null \
    | jq -r --arg dl "$dl" '[.[] | select((.dl // "" | ascii_upcase) == $dl)][0].id // empty')"
  if [[ -n "$card" ]]; then
    if $KB $flag move --task "$card" --column in_review >/dev/null 2>&1; then
      echo "$(date -u +%FT%TZ) create: ${dl} #${card} -> In Review (${board})" >> "$LOG"
    else
      echo "$(date -u +%FT%TZ) create: ${dl} #${card} move FAILED (${board})" >> "$LOG"
    fi
    exit 0
  fi
done
echo "$(date -u +%FT%TZ) create: no card for ${dl}, skip" >> "$LOG"
exit 0
