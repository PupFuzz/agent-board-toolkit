#!/usr/bin/env bash
# release-pr-body — deterministically generate a release-PR body scaffold from git.
#
# Generic across repos: reads `.release-pr.json` in the repo root for per-project
# config. The MECHANICAL parts (the bundled-work list, the artifact checklist, the
# version line, the range) are derived from git truth and are 100% deterministic —
# no AI, no hand-curation. The one genuinely non-deterministic part, the
# human-readable "## Highlights", is left as a marked placeholder for the author
# (human or AI) to fill. That split is the design: automate the mechanical, leave
# only judgement to a person.
#
# Usage:
#   release-pr-body [--version X.Y.Z] [--base REF] [--head REF] [--config PATH]
#   release-pr-body --manifest        # print just the machine-readable shipped-ref list (one per line)
#
# Exit non-zero on a config/usage error, or when the baseline fetch from origin
# fails — a baseline read from a stale local ref reports already-shipped PRs as
# new, which is worse than no body (pass --base <tag> as the explicit offline
# override). An empty range yields an empty (but valid) bundled section, not a
# failure.
set -euo pipefail

die() { echo "release-pr-body: $*" >&2; exit 2; }
command -v jq  >/dev/null || die "jq is required"
command -v git >/dev/null || die "git is required"

CONFIG=".release-pr.json"; VERSION=""; BASE=""; HEAD_REF=""; MANIFEST_ONLY=0
while [ $# -gt 0 ]; do
  case "$1" in
    --version) VERSION="$2"; shift 2;;
    --base)    BASE="$2"; shift 2;;
    --head)    HEAD_REF="$2"; shift 2;;
    --config)  CONFIG="$2"; shift 2;;
    --manifest) MANIFEST_ONLY=1; shift;;
    -h|--help) sed -n '2,20p' "$0"; exit 0;;
    *) die "unknown arg '$1'";;
  esac
done

[ -f "$CONFIG" ] || die "no $CONFIG in this repo (per-project config — see the kanban-board copy for the shape)"
cfg() { jq -re "$1" "$CONFIG" 2>/dev/null; }
cfg_opt() { jq -r "$1 // empty" "$CONFIG" 2>/dev/null; }

MAIN_BRANCH="$(cfg_opt '.main_branch')"; MAIN_BRANCH="${MAIN_BRANCH:-main}"
DEV_BRANCH="$(cfg_opt '.dev_branch')";  DEV_BRANCH="${DEV_BRANCH:-dev}"
VERSION_FILE="$(cfg_opt '.version_file')"
VERSION_REGEX="$(cfg_opt '.version_regex')"
REF_TOKEN_REGEX="$(cfg_opt '.ref_token_regex')"   # e.g. "DL-[0-9]+"; optional
TITLE_PREFIX="$(cfg_opt '.title_prefix')"; TITLE_PREFIX="${TITLE_PREFIX:-Release}"
# How a version maps to its git tag name, with {{version}} as the placeholder
# (symmetric with the `artifacts` template expansion below). Default `v{{version}}`
# preserves the historical `v`-prefixed exclude; a non-prefixed scheme sets e.g.
# "{{version}}" (the date string IS the tag) or "release-{{version}}".
# NB: default assigned on its own line for readability. (An earlier comment here
# claimed `${VAR:-v{{version}}}` mis-parses on the `}}` — tested false in bash/sh;
# the inline form works. The two-line form is kept as the clearer one.)
TAG_FORMAT="$(cfg_opt '.tag_format')"; [ -n "$TAG_FORMAT" ] || TAG_FORMAT='v{{version}}'

# Resolve the version: explicit flag, else extract from the version file. The
# numeric extraction accepts 2-4 segments (SemVer 3-segment AND .NET 4-segment
# Major.Minor.Build.Revision) — matching changelog-tag-coverage.py; a 3-segment-
# only pattern here would silently truncate a 4-segment version (1.22.1.0→1.22.1).
if [ -z "$VERSION" ] && [ -n "$VERSION_FILE" ] && [ -n "$VERSION_REGEX" ] && [ -f "$VERSION_FILE" ]; then
  VERSION="$(grep -oiE "$VERSION_REGEX" "$VERSION_FILE" | head -1 | grep -oE '[0-9]+(\.[0-9]+){1,3}' | head -1 || true)"
fi
[ -n "$VERSION" ] || die "could not resolve version (pass --version or set version_file+version_regex)"

# Range: BASE = last release tag reachable on ORIGIN's main (excluding THIS
# version's tag, in case it already exists — else a re-run after tagging returns
# the current release as its own 'previous tag'), HEAD = the work about to ship
# (dev default). The baseline MUST come from the remote: the documented
# branch-off-dev release flow never checks out the local main ref, so it drifts a
# full release behind every cycle — a local `describe` names an already-shipped
# tag and the body reports shipped PRs as new. Fetch with tags (release tags point
# at main-only merge commits a dev-side fetch's tag auto-follow never brings over);
# a fetch failure is FATAL rather than a silent fall-back to the stale local ref.
# An explicit --base skips the fetch entirely. The excluded tag name is derived
# from tag_format, not a hardcoded `v` prefix (preserves .NET / date tag schemes).
HEAD_REF="${HEAD_REF:-$DEV_BRANCH}"
if [ -z "$BASE" ]; then
  THIS_TAG="${TAG_FORMAT//\{\{version\}\}/$VERSION}"
  git fetch --quiet --tags origin "$MAIN_BRANCH" \
    || die "cannot fetch origin/'$MAIN_BRANCH' — the release baseline is resolved against the remote (the local '$MAIN_BRANCH' ref is stale by design under the branch-off-'$DEV_BRANCH' release flow, so it is NOT a usable fallback); fix network/remote access or pass an explicit --base <tag>"
  MAIN_TIP="$(git rev-parse --verify -q "refs/remotes/origin/$MAIN_BRANCH" || git rev-parse --verify -q FETCH_HEAD)" \
    || die "fetched origin '$MAIN_BRANCH' but cannot resolve its tip"
  LOCAL_TIP="$(git rev-parse --verify -q "refs/heads/$MAIN_BRANCH" || true)"
  if [ -n "$LOCAL_TIP" ] && [ "$LOCAL_TIP" != "$MAIN_TIP" ]; then
    echo "release-pr-body: note: local '$MAIN_BRANCH' ($(git rev-parse --short "$LOCAL_TIP")) is behind/apart from origin/$MAIN_BRANCH ($(git rev-parse --short "$MAIN_TIP")) — expected under the release flow; the baseline uses the remote tip." >&2
  fi
  BASE="$(git describe --tags --abbrev=0 --exclude="$THIS_TAG" "$MAIN_TIP" 2>/dev/null || true)"
fi
RANGE="${BASE:+$BASE..}$HEAD_REF"

# Deterministic bundle: each non-merge commit subject in the range, with its PR
# number (trailing "(#NNN)") and optional project ref token pulled out of git —
# never hand-curated.
emit_manifest() {
  [ -n "$REF_TOKEN_REGEX" ] || return 0
  # `|| true`: grep exits 1 on no match — a release with no ref tokens is valid,
  # not a failure (would otherwise abort under `set -o pipefail`).
  { git log "$RANGE" --no-merges --format='%s' 2>/dev/null \
    | grep -oiE "$REF_TOKEN_REGEX" | tr '[:lower:]' '[:upper:]' | awk '!seen[$0]++'; } || true
}

if [ "$MANIFEST_ONLY" = 1 ]; then
  emit_manifest
  exit 0
fi

bundle_lines() {
  local found=0
  while IFS=$'\t' read -r subj; do
    [ -n "$subj" ] || continue
    found=1
    local pr ref
    pr="$(printf '%s' "$subj" | grep -oE '\(#[0-9]+\)' | tail -1 | tr -d '(#)')"
    if [ -n "$REF_TOKEN_REGEX" ]; then
      ref="$(printf '%s' "$subj" | grep -oiE "$REF_TOKEN_REGEX" | head -1 | tr '[:lower:]' '[:upper:]')"
    else ref=""; fi
    local clean; clean="$(printf '%s' "$subj" | sed -E 's/ *\(#[0-9]+\)$//')"
    printf -- '- %s%s%s\n' \
      "${pr:+**#$pr** }" \
      "${ref:+(\`$ref\`) }" \
      "$clean"
  done < <(git log "$RANGE" --no-merges --format='%s' 2>/dev/null)
  [ "$found" = 1 ] || echo "_(no non-merge commits in \`$RANGE\`)_"
}

# Shift-left card coverage: surface, IN THE RELEASE PR, any shipped DL that has no
# board tracking card — so the gap is caught at release-prep (cheap to fix) instead of
# only on the post-merge promote run (a red check needing manual board surgery). Reuses
# `promote-released-cards --dls <manifest> --dry-run` (the --dls path → no squash/
# parent-count branch, just the cardless report). Best-effort: needs the promote tool +
# a board token + a `.promote` config; otherwise a static reminder.
card_coverage_section() {
  [ -n "$REF_TOKEN_REGEX" ] || return 0
  echo ""; echo "## Card coverage"
  local board promote
  board="$(cfg_opt '.promote.board_id')"
  promote="$(command -v promote-released-cards 2>/dev/null || true)"
  if [ -z "$promote" ]; then
    local d; d="$(dirname "$0")"
    [ -x "$d/promote-released-cards" ] && promote="$d/promote-released-cards"
  fi
  if [ -z "$board" ] || [ -z "${KANBAN_WRITEBACK_TOKEN:-}" ] || [ -z "$promote" ]; then
    echo "_Not checked here (needs a board token + a \`.promote\` config + the promote tool). Run \`promote-released-cards --dry-run\` before merge._"
    return 0
  fi
  local manifest
  manifest="$(emit_manifest | paste -sd, -)"
  if [ -z "$manifest" ]; then echo "_No shipped DL refs in range._"; return 0; fi
  # --dls dry-run never moves and never hits the squash/parent-count branch, so a
  # non-zero exit is a real error (bad token / board read) — distinguish it from a
  # clean run, else a failed check would falsely read as "all carded".
  local out rc
  out="$("$promote" --dls "$manifest" --dry-run 2>&1)" && rc=0 || rc=$?
  if [ "${rc:-0}" -ne 0 ]; then
    echo "_Coverage check could not run (\`promote-released-cards\` exited ${rc}). Run it manually before merge._"
    return 0
  fi
  local miss
  miss="$(printf '%s\n' "$out" | grep -oE 'matched NO card[^:]*: .*' | sed 's/[^:]*: //' || true)"
  if [ -n "$miss" ]; then
    echo "⚠ **Shipped DLs with no tracking card:** $miss"
    echo ""
    echo "Create a board card for each before merging — a cardless *feature* DL is a tracking gap; a cardless *docs* DL is acceptable but better carded. Otherwise the post-merge promote step reports them as no-card."
  else
    echo "_All shipped DLs have a tracking card._"
  fi
}

COUNT="$(git log "$RANGE" --no-merges --oneline 2>/dev/null | wc -l | tr -d ' ')"

# --- the body --------------------------------------------------------------
cat <<EOF
**\`${DEV_BRANCH} → ${MAIN_BRANCH}\` release PR — v${VERSION}.** Bundles ${COUNT} commit(s) since ${BASE:-the start}.

## Highlights
<!-- AUTHOR: write the 1–3 human-readable highlights of this release here. This is
     the ONLY non-deterministic section — everything below is generated from git. -->

## Bundled (generated — do not hand-edit)
$(bundle_lines)
EOF

# Optional artifact checklist from config (each {{version}} expanded).
if jq -e '.artifacts | type == "array"' "$CONFIG" >/dev/null 2>&1; then
  echo ""; echo "## Release artifacts"
  jq -r '.artifacts[]' "$CONFIG" | while IFS= read -r a; do
    printf -- '- [ ] %s\n' "${a//\{\{version\}\}/$VERSION}"
  done
fi

card_coverage_section

# Machine-readable manifest of shipped refs — a deterministic footer a downstream
# consumer (e.g. a bridge classifier) can parse instead of the prose above.
if [ -n "$REF_TOKEN_REGEX" ]; then
  MANIFEST="$(emit_manifest | paste -sd, -)"
  [ -n "$MANIFEST" ] && printf '\n<!-- release-manifest:shipped-refs=%s -->\n' "$MANIFEST"
fi
