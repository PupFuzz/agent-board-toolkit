#!/usr/bin/env bash
# board-session-close — session-close reconciliation ritual. RUN ON DEMAND when
# the user says they're closing / wrapping up the session. Puts board in-flight
# state next to local branch/PR reality so any drift (a card that no longer
# matches what git/PRs show) gets fixed BEFORE the session ends. Read-only — it
# surfaces what to reconcile; the actual kbcard writes are the agent's call.
#
# The inverse-drift leg (In-Review cards tracking no open PR) is DELEGATED to the
# shipped, framework-maintained `kanban-reconcile.py --detect` — the sanctioned
# conforming implementation of the inverse-drift CONTRACT (the framework coord
# plugin's BOARD-SYNC.md § "The detect backstop contract (inverse-drift)"). It
# reads the same boards from the coord config (kanban.boards[]) and is READ-ONLY
# by construction, plus adds a forward un-carded-open-PR leg the retired bash
# check never had.
set -uo pipefail

# resolve_reconcile_hook — locate the shipped kanban-reconcile.py detect hook
# WITHOUT a version-pinned path (a future plugin bump must not break this). Prints
# the resolved path on stdout (rc 0), or rc 1 if none of the sources have it — the
# caller then fails LOUD rather than silently skipping the drift check. Order:
#   1. $KANBAN_RECONCILE_HOOK explicit operator override.
#   2. The coord plugin version THIS session loaded (its dir is named on $PATH) —
#      runs the exact version the rest of the session's coord tooling uses.
#   3. The git-maintained marketplace clone (stable, version-less path).
#   4. The newest cached plugin version carrying the hook (sort -V).
resolve_reconcile_hook() {
  local rel="hooks/bin/kanban-reconcile.py" c pdir
  if [[ -n "${KANBAN_RECONCILE_HOOK:-}" ]]; then
    [[ -f "$KANBAN_RECONCILE_HOOK" ]] && { printf '%s' "$KANBAN_RECONCILE_HOOK"; return 0; }
    return 1
  fi
  pdir="$(printf '%s\n' "${PATH//:/$'\n'}" | grep -m1 '/agent-board-framework/coord/[^/]*/bin$' 2>/dev/null || true)"
  if [[ -n "$pdir" ]]; then
    c="${pdir%/bin}/$rel"
    [[ -f "$c" ]] && { printf '%s' "$c"; return 0; }
  fi
  c="$HOME/.claude/plugins/marketplaces/agent-board-framework/plugins/coord/$rel"
  [[ -f "$c" ]] && { printf '%s' "$c"; return 0; }
  # A non-matching glob stays literal (no nullglob) → the trailing -f guard rejects it.
  c="$(printf '%s\n' "$HOME"/.claude/plugins/cache/agent-board-framework/coord/*/"$rel" | sort -V | tail -1)"
  [[ -n "$c" && -f "$c" ]] && { printf '%s' "$c"; return 0; }
  return 1
}

main() {
  local d wt b dirty hook rc out line cur_key
  echo "═══ SESSION-CLOSE RECONCILIATION ═══"
  echo "Fix any board card below that doesn't match the git/PR reality, then close."
  echo
  "$HOME/.local/bin/board-snapshot" 2>/dev/null || echo "(board-snapshot unavailable)"
  echo
  echo "── Local branch reality (cross-check against the cards above) ──"
  for d in agent-webhook-bridge-dev agent-webhook-bridge-prod kanbanboard; do
    wt="/home/kanban/$d"
    [[ -e "$wt/.git" ]] || continue
    b="$(git -C "$wt" branch --show-current 2>/dev/null || true)"
    dirty=""; [[ -n "$(git -C "$wt" status --porcelain 2>/dev/null)" ]] && dirty=" (uncommitted changes)"
    echo "• ${d}: branch=${b:-?}${dirty}"
  done
  echo
  echo "── Open PRs (each should have a card in In Review / Held) ──"
  for d in agent-webhook-bridge-dev kanbanboard agent-board-toolkit; do   # one entry per unique repo
    wt="/home/kanban/$d"
    [[ -e "$wt/.git" ]] || continue
    ( cd "$wt" 2>/dev/null && gh pr list --state open --limit 10 2>/dev/null \
        | sed "s#^#  ${d}: #" ) || true
  done
  echo
  echo "── Inverse-drift check — In-Review cards with NO open PR (#3651), plus un-carded open PRs ──"
  echo "   (delegated to the shipped kanban-reconcile.py --detect; read-only)"
  if ! hook="$(resolve_reconcile_hook)"; then
    {
      echo "  ⚠ board-session-close: could NOT locate the shipped kanban-reconcile.py --detect hook."
      echo "    The inverse-drift check DID NOT RUN — do not close on an un-run drift check."
      echo "    Searched: \$KANBAN_RECONCILE_HOOK, the coord plugin dir on \$PATH, the marketplace"
      echo "    clone (~/.claude/plugins/marketplaces/agent-board-framework/plugins/coord/hooks/bin/),"
      echo "    and the plugin cache (~/.claude/plugins/cache/agent-board-framework/coord/*/hooks/bin/)."
      echo "    Fix: run /coord:update (or reinstall the coord plugin), or set KANBAN_RECONCILE_HOOK."
    } >&2
    return 1
  fi
  out="$(python3 "$hook" --detect 2>&1)"; rc=$?
  printf '%s\n' "$out" | sed 's/^/  /'
  # The hook's inverse leg is config-gated: a board without inverse_check_columns
  # runs the FORWARD leg only and reports 'inverse check OFF' at rc 0 — a PASS that
  # silently drops the In-Review-without-open-PR check the retired bash always ran.
  # A board absent/mis-declared in kanban.boards[] is 'skipped' at rc 0 the same way.
  # Re-surface both as a LOUD ⚠ on stderr, OUTSIDE the per-board '(no drift detected)'
  # framing, so the degraded coverage is never read as a clean pass (canon #9).
  cur_key=""
  while IFS= read -r line; do
    case "$line" in
      *"[DETECT] board"*"skipped"*)
        cur_key="${line%%):*}"; cur_key="${cur_key##*(}"
        echo "  ⚠ board ${cur_key:-?} was SKIPPED by kanban-reconcile.py --detect (${line#*"): "}) — it got NO inverse-drift check this run; declare its board_id + a single-repo kanban.boards[].repo to cover it" >&2
        ;;
      *"[DETECT] board"*"):"*)
        cur_key="${line%%):*}"; cur_key="${cur_key##*(}"
        ;;
      *"inverse check OFF"*)
        echo "  ⚠ inverse-drift check is OFF for board ${cur_key:-?} — arm inverse_check_columns in kanban.boards[] (coordination.config.json) or this ritual silently skips the In-Review-without-open-PR check" >&2
        ;;
    esac
  done <<< "$out"
  if [[ "$rc" -ne 0 ]]; then
    echo "  ⚠ kanban-reconcile.py --detect exited $rc — the inverse-drift check may be INCOMPLETE" >&2
    echo "    (config/API error above); investigate before treating the board as reconciled." >&2
    return "$rc"
  fi
  return 0
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
